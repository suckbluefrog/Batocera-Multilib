# Disable OpenCV Python bindings in i386 multilib to avoid selecting
# python-numpy, which fails on i386 long double ABI in numpy 1.25 meson checks.
# BR2_PACKAGE_OPENCV4_LIB_PYTHON is not set
BR2_PACKAGE_OPENCV4_LIB_VIDEOIO=y
