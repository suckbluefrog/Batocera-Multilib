# batocera-zen3_i386_libs.packages
# Phase 5a: steam-core i386 runtime set (no Wine32 payload yet)

# Reuse the same dependency baseline as native x86_64 Steam.
BR2_PACKAGE_BATOCERA_STEAM_REQUIREMENTS=y

# 32-bit GL/Vulkan stack (priority for phase 5a)
BR2_PACKAGE_MESA3D_LLVM=y
