config BR2_PACKAGE_SPICE_GTK
	bool "spice-gtk"
	depends on !BR2_STATIC_LIBS
	depends on BR2_USE_MMU
	depends on BR2_USE_WCHAR
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_PACKAGE_GOBJECT_INTROSPECTION_ARCH_SUPPORTS
	depends on BR2_TOOLCHAIN_USES_GLIBC
	select BR2_PACKAGE_GOBJECT_INTROSPECTION
	select BR2_PACKAGE_GSTREAMER1
	select BR2_PACKAGE_GST1_PLUGINS_BASE
	select BR2_PACKAGE_JSON_GLIB
	select BR2_PACKAGE_JPEG
	select BR2_PACKAGE_LIBGTK3
	select BR2_PACKAGE_LIBGTK3_X11
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_PIXMAN
	select BR2_PACKAGE_SPICE_PROTOCOL
	select BR2_PACKAGE_ZLIB
	help
	  spice-gtk client libraries and GI typelibs used by virt-manager
	  for SPICE graphical consoles.

	  https://www.spice-space.org/

comment "spice-gtk needs a glibc toolchain, wchar, threads, dynamic library"
	depends on BR2_USE_MMU
	depends on BR2_PACKAGE_GOBJECT_INTROSPECTION_ARCH_SUPPORTS
	depends on BR2_STATIC_LIBS || !BR2_USE_WCHAR || !BR2_TOOLCHAIN_HAS_THREADS || !BR2_TOOLCHAIN_USES_GLIBC
