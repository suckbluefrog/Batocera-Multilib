}

deploy_plex() {
    local tz
    local -a dri_arg=()

    tz="$(get_timezone)"
    if [ -e /dev/dri ]; then
        dri_arg=(--device /dev/dri:/dev/dri)
    fi
    mkdir -p /userdata/system/plex/config /userdata/system/plex/tv /userdata/system/plex/movies
    remove_container_if_exists plex

    docker run -d \
        --name plex \
        --net host \
        -e PUID="$(id -u)" \
        -e PGID="$(id -g)" \
        -e TZ="${tz}" \
        -e VERSION=docker \
        -v /userdata/system/plex/config:/config \
        -v /userdata/system/plex/tv:/tv \
        -v /userdata/system/plex/movies:/movies \
        "${dri_arg[@]}" \
        --restart unless-stopped \
        lscr.io/linuxserver/plex:latest >/dev/null || return 1

    DEPLOY_NOTE="Plex: http://<batocera-ip>:32400/web"
    return 0
}

