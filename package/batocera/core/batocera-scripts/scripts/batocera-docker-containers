    DEPLOY_NOTE="Umbrel: http://<batocera-ip>:${host_port}"
    return 0
}

deploy_webtop() {
    local http_port https_port flavor tz
    local -a dri_arg=()

    require_x86_64 || return 1

    http_port="$(find_free_port 3000)"
    https_port="$(find_free_port 3001)"
    flavor="latest"
    tz="$(get_timezone)"
    if [ -e /dev/dri ]; then
        dri_arg=(--device /dev/dri:/dev/dri)
    fi

    if [ "${HAS_DIALOG}" -eq 1 ]; then
        http_port="$(prompt_input "Enter Webtop HTTP port" "${http_port}")" || return 1
        https_port="$(prompt_input "Enter Webtop HTTPS port" "${https_port}")" || return 1

        flavor="$(dialog --stdout --menu "Choose Webtop flavor" 20 70 14 \
            "latest" "XFCE Alpine (default)" \
            "ubuntu-xfce" "XFCE Ubuntu" \
            "fedora-xfce" "XFCE Fedora" \
            "arch-xfce" "XFCE Arch" \
            "alpine-kde" "KDE Alpine" \
            "ubuntu-kde" "KDE Ubuntu" \
            "fedora-kde" "KDE Fedora" \
            "arch-kde" "KDE Arch" \
            "alpine-mate" "MATE Alpine" \
            "ubuntu-mate" "MATE Ubuntu" \
            "fedora-mate" "MATE Fedora" \
            "arch-mate" "MATE Arch" \
            "alpine-i3" "i3 Alpine" \
            "ubuntu-i3" "i3 Ubuntu")"
        if [ $? -ne 0 ] || [ -z "${flavor}" ]; then
            return 1
        fi
        clear
    fi

    mkdir -p /userdata/system/webtop
    remove_container_if_exists webtop

    docker run -d \
        --name webtop \
        --security-opt seccomp=unconfined \
        -e PUID="$(id -u)" \
        -e PGID="$(id -g)" \
        -e TZ="${tz}" \
        -e SUBFOLDER=/ \
        -e TITLE="Webtop" \
        -p "${http_port}:3000" \
        -p "${https_port}:3001" \
        -v /userdata/system/webtop:/config \
        -v /var/run/docker.sock:/var/run/docker.sock \
        "${dri_arg[@]}" \
        --shm-size="1gb" \
        --restart unless-stopped \
        "lscr.io/linuxserver/webtop:${flavor}" >/dev/null || return 1

    DEPLOY_NOTE="Webtop: http://<batocera-ip>:${http_port}"
    return 0
}

deploy_netboot() {
    local iface dhcp_start container_ip gateway subnet

    require_x86_64 || return 1

    iface="$(ip route | awk '/default/ { print $5; exit }')"
    gateway="$(ip route | awk '/default/ { print $3; exit }')"

    iface="$(prompt_input "Network interface" "${iface}")" || return 1
    dhcp_start="$(prompt_input "DHCP range start IP" "192.168.0.10")" || return 1
    container_ip="$(prompt_input "Container IP" "192.168.0.250")" || return 1
    gateway="$(prompt_input "Gateway IP" "${gateway}")" || return 1
    subnet="$(prompt_input "Subnet CIDR" "192.168.0.0/24")" || return 1

    remove_container_if_exists netbootxyz

    docker run -d \
        --name netbootxyz \
        --net=host \
        --cap-add=NET_ADMIN \
        -e INTERFACE="${iface}" \
        -e DHCP_RANGE_START="${dhcp_start}" \
        -e GATEWAY="${gateway}" \
        -e SUBNET="${subnet}" \
        -e CONTAINER_IP="${container_ip}" \
        samdbmg/dhcp-netboot.xyz >/dev/null || return 1

    DEPLOY_NOTE="Netboot.xyz running on interface ${iface}"
    return 0
}

deploy_windows() {
    local rdp_port vnc_port version ram_size disk_size cpu_cores windows_dir container_name

    require_x86_64 || return 1

    if [ ! -e /dev/kvm ]; then
        show_msg "Windows container requires /dev/kvm. KVM is not available on this system."
        return 1
    fi

    rdp_port="$(find_free_port 3389)"
    vnc_port="$(find_free_port 8006)"

    if [ "${HAS_DIALOG}" -eq 1 ]; then
        version="$(dialog --stdout --menu "Choose Windows version" 22 70 14 \
            "11" "Windows 11 Pro" \
            "11l" "Windows 11 LTSC" \
            "11e" "Windows 11 Enterprise" \
            "10" "Windows 10 Pro" \
            "10l" "Windows 10 LTSC" \
            "10e" "Windows 10 Enterprise" \
            "2025" "Windows Server 2025" \
            "2022" "Windows Server 2022" \
            "2019" "Windows Server 2019" \
            "2016" "Windows Server 2016" \
            "2012" "Windows Server 2012 R2" \
            "2008" "Windows Server 2008 R2" \
            "2003" "Windows Server 2003" \
            "xp" "Windows XP Pro")"
        if [ $? -ne 0 ] || [ -z "${version}" ]; then
            return 1
        fi
        clear

        ram_size="$(dialog --stdout --menu "RAM size" 14 40 7 \
            "4G" "4 GB" \
            "8G" "8 GB" \
            "12G" "12 GB" \
            "16G" "16 GB" \
            "24G" "24 GB" \
            "32G" "32 GB")"
        if [ $? -ne 0 ] || [ -z "${ram_size}" ]; then
            return 1
        fi
        clear

        disk_size="$(dialog --stdout --menu "Disk size" 14 40 7 \
            "64G" "64 GB" \
            "128G" "128 GB" \
            "256G" "256 GB" \
            "512G" "512 GB" \
            "1024G" "1 TB")"
        if [ $? -ne 0 ] || [ -z "${disk_size}" ]; then
            return 1
        fi
        clear

        cpu_cores="$(dialog --stdout --menu "CPU cores" 12 40 4 \
            "2" "2 cores" \
            "4" "4 cores" \
            "6" "6 cores" \
            "8" "8 cores")"
        if [ $? -ne 0 ] || [ -z "${cpu_cores}" ]; then
            return 1
        fi
        clear

        rdp_port="$(prompt_input "RDP port" "${rdp_port}")" || return 1
        vnc_port="$(prompt_input "VNC/Web port" "${vnc_port}")" || return 1
    else
        version="11"
        ram_size="8G"
        disk_size="128G"
        cpu_cores="4"
    fi

    windows_dir="$(find_next_windows_dir)"
    mkdir -p "${windows_dir}"

    container_name="windows_${version}"
    remove_container_if_exists "${container_name}"

    docker run -d \
        --name "${container_name}" \
        -e VERSION="${version}" \
        -e RAM_SIZE="${ram_size}" \
        -e DISK_SIZE="${disk_size}" \
        -e CPU_CORES="${cpu_cores}" \
        --device /dev/kvm \
        --cap-add NET_ADMIN \
        -p "${rdp_port}:3389/tcp" \
        -p "${rdp_port}:3389/udp" \
        -p "${vnc_port}:8006/tcp" \
        --stop-timeout 120 \
        --restart on-failure \
        -v "${windows_dir}:/storage" \
        dockurr/windows >/dev/null || return 1

    DEPLOY_NOTE="Windows: VNC http://<batocera-ip>:${vnc_port} | RDP port ${rdp_port} | Storage ${windows_dir}"
    return 0
}

deploy_bliss() {
    local spice_port adb_port ssh_port
    local -a dri_arg=()
    local -a snd_arg=()

    require_x86_64 || return 1

    if [ ! -e /dev/kvm ]; then
        show_msg "Bliss container requires /dev/kvm. KVM is not available on this system."
        return 1
    fi

    if ! ask_yesno "Bliss OS container is experimental (no audio/GPU acceleration expected). Continue?"; then
        return 1
    fi

    spice_port="$(find_free_port 5930)"
    adb_port="$(find_free_port 5555)"
    ssh_port="$(find_free_port 50922)"
    if [ -e /dev/dri ]; then
        dri_arg=(--device /dev/dri --group-add video)
    fi
    if [ -e /dev/snd ]; then
        snd_arg=(--device /dev/snd --group-add audio)
    fi

    remove_container_if_exists bliss

    docker run -d \
        --name bliss \
        --privileged \
        --device /dev/kvm \
        -v /tmp/.X11-unix:/tmp/.X11-unix \
        -e DISPLAY="${DISPLAY:-:0.0}" \
        --net=host \
        -p "${adb_port}:5555" \
        -p "${ssh_port}:10022" \
        "${dri_arg[@]}" \
        "${snd_arg[@]}" \
        -e EXTRA="-display gtk,gl=on -vga qxl -spice port=${spice_port},disable-ticketing" \
        sickcodes/dock-droid:latest >/dev/null || return 1

    DEPLOY_NOTE="Bliss OS container started (SPICE ${spice_port})"
    return 0
}

container_label() {
    case "$1" in
        portainer) echo "Portainer" ;;
        casa2) echo "CasaOS (casa2)" ;;
        emby) echo "Emby" ;;
        jellyfin) echo "Jellyfin" ;;
        nextcloud) echo "Nextcloud" ;;
        plex) echo "Plex" ;;
        sabnzbd) echo "SABnzbd" ;;
        systools) echo "System Tools" ;;
        umbrel) echo "Umbrel" ;;
        webtop) echo "Webtop" ;;
        netboot) echo "Netboot.xyz" ;;
        windows) echo "Windows" ;;
        bliss) echo "Bliss OS" ;;
        *) echo "$1" ;;
    esac
}

run_choice() {
    DEPLOY_NOTE=""
    case "$1" in
        portainer) deploy_portainer ;;
        casa2) deploy_casa2 ;;
        emby) deploy_emby ;;
        jellyfin) deploy_jellyfin ;;
        nextcloud) deploy_nextcloud ;;
        plex) deploy_plex ;;
        sabnzbd) deploy_sabnzbd ;;
        systools) deploy_systools ;;
        umbrel) deploy_umbrel ;;
        webtop) deploy_webtop ;;
        netboot) deploy_netboot ;;
        windows) deploy_windows ;;
        bliss) deploy_bliss ;;
        *)
            log "Unknown choice: $1"
            return 1
            ;;
    esac
}

choose_with_dialog() {
    local -a items
    items=(
        "portainer" "Portainer CE (9443)" "off"
        "casa2" "CasaOS (casa2 only)" "off"
        "emby" "Emby media server" "off"
        "jellyfin" "Jellyfin media server" "off"
        "nextcloud" "Nextcloud" "off"
        "plex" "Plex media server" "off"
        "sabnzbd" "SABnzbd" "off"
        "systools" "System tools (Glances/Wetty/Filemanager)" "off"
        "umbrel" "Umbrel" "off"
        "webtop" "Webtop desktop" "off"
        "netboot" "Netboot.xyz" "off"
        "windows" "Windows container" "off"
        "bliss" "Bliss OS (experimental)" "off"
    )

    dialog --stdout --separate-output --checklist \
        "Select Docker containers to deploy.\n\nSingle-script mode: no external apps/docker scripts are called." \
        24 90 16 "${items[@]}"
}

choose_without_dialog() {
    cat <<'TXT'
Select one or more (space separated):
portainer casa2 emby jellyfin nextcloud plex sabnzbd systools umbrel webtop netboot windows bliss
TXT
    read -r -a arr
    printf '%s\n' "${arr[@]}"
}

main() {
    local selected
    local -a choices=()
    local -a successes=()
    local -a failures=()
    local -a notes=()
    local choice clean_choice

    if ! ensure_docker_ready; then
        exit 1
    fi

    if [ "${HAS_DIALOG}" -eq 1 ]; then
        selected="$(choose_with_dialog)"
        if [ $? -ne 0 ] || [ -z "${selected}" ]; then
            clear
            exit 0
        fi
        mapfile -t choices <<<"${selected}"
    else
        mapfile -t choices < <(choose_without_dialog)
        if [ "${#choices[@]}" -eq 0 ]; then
            exit 0
        fi
    fi

    for choice in "${choices[@]}"; do
        clean_choice="${choice//\"/}"
        show_info "Deploying $(container_label "${clean_choice}")..."
        log "Deploy start ${clean_choice}"
        if run_choice "${clean_choice}"; then
            successes+=("$(container_label "${clean_choice}")")
            if [ -n "${DEPLOY_NOTE}" ]; then
                notes+=("${DEPLOY_NOTE}")
            fi
            log "Deploy success ${clean_choice}"
        else
            failures+=("$(container_label "${clean_choice}")")
            log "Deploy failed ${clean_choice}"
        fi
    done

    local summary
    summary="Completed Docker container deployment."

    if [ "${#successes[@]}" -gt 0 ]; then
        summary+="\n\nSucceeded:\n- $(printf '%s\n- ' "${successes[@]}" | sed 's/- $//')"
    fi

    if [ "${#failures[@]}" -gt 0 ]; then
        summary+="\n\nFailed:\n- $(printf '%s\n- ' "${failures[@]}" | sed 's/- $//')"
    fi

    if [ "${#notes[@]}" -gt 0 ]; then
        summary+="\n\nEndpoints/Notes:\n- $(printf '%s\n- ' "${notes[@]}" | sed 's/- $//')"
    fi

    summary+="\n\nLog: ${LOG_FILE}"
    show_msg "${summary}"
}

main "$@"
