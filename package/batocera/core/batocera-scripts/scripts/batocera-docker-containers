#!/bin/bash

set -u

TITLE="Batocera Docker Containers"
DATA_ROOT="/userdata/system/docker-data"
LOG_DIR="/userdata/system/logs"
LOG_FILE="${LOG_DIR}/batocera-docker-containers.log"
PORTAINER_TEMPLATE_DST="${DATA_ROOT}/portainer/templates.json"

HAS_DIALOG=0
if command -v dialog >/dev/null 2>&1; then
    HAS_DIALOG=1
fi

mkdir -p "${LOG_DIR}" >/dev/null 2>&1 || true

log() {
    printf '[%s] %s\n' "$(date '+%F %T')" "$*" >>"${LOG_FILE}"
}

show_msg() {
    local text="$1"

    if [ "${HAS_DIALOG}" -eq 1 ]; then
        dialog --title "${TITLE}" --msgbox "${text}" 18 88
        clear
    else
        echo
        echo "${text}"
        echo
    fi
}

show_info() {
    local text="$1"

    if [ "${HAS_DIALOG}" -eq 1 ]; then
        dialog --title "${TITLE}" --infobox "${text}" 8 78
        sleep 1
        clear
    else
        echo "${text}"
    fi
}

ask_yesno() {
    local text="$1"

    if [ "${HAS_DIALOG}" -eq 1 ]; then
        dialog --title "${TITLE}" --yesno "${text}" 12 88
        local rc=$?
        clear
        return "${rc}"
    fi

    printf "%s [y/N]: " "${text}"
    read -r answer
    case "${answer}" in
        y|Y|yes|YES)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

prompt_input() {
    local prompt="$1"
    local default_value="$2"
    local out=""

    if [ "${HAS_DIALOG}" -eq 1 ]; then
        out="$(dialog --stdout --inputbox "${prompt}" 10 78 "${default_value}")"
        if [ $? -ne 0 ]; then
            echo ""
            return 1
        fi
        clear
        echo "${out}"
        return 0
    fi

    printf "%s [%s]: " "${prompt}" "${default_value}"
    read -r out
    if [ -z "${out}" ]; then
        out="${default_value}"
    fi
    echo "${out}"
    return 0
}

get_timezone() {
    cat /etc/timezone 2>/dev/null || echo "Etc/UTC"
}

is_x86_64() {
    [ "$(uname -m)" = "x86_64" ]
}

require_x86_64() {
    if ! is_x86_64; then
        show_msg "This option requires x86_64 hardware. Current architecture: $(uname -m)"
        return 1
    fi
    return 0
}

port_in_use() {
    local port="$1"

    if command -v ss >/dev/null 2>&1; then
        ss -lntu 2>/dev/null | awk '{print $5}' | grep -qE "[:.]${port}$"
        return $?
    fi

    if command -v netstat >/dev/null 2>&1; then
        netstat -tuln 2>/dev/null | awk '{print $4}' | grep -qE "[:.]${port}$"
        return $?
    fi

    return 1
}

find_free_port() {
    local port="$1"
    while port_in_use "${port}"; do
        port=$((port + 1))
    done
    echo "${port}"
}

service_exists() {
    local marker
    marker="$(batocera-services list all 2>/dev/null | awk -F';' '$1=="docker" { print $2; exit }')"
    [ -n "${marker}" ]
}

service_enabled() {
    local marker
    marker="$(batocera-services list all 2>/dev/null | awk -F';' '$1=="docker" { print $2; exit }')"
    [ "${marker}" = "*" ]
}

service_started() {
    batocera-services status docker 2>/dev/null | grep -q '^started$'
}

ensure_docker_ready() {
    if ! command -v docker >/dev/null 2>&1; then
        show_msg "Docker CLI is not installed. Enable/install Docker first from Batocera services/settings."
        return 1
    fi

    if service_exists; then
        if ! service_enabled; then
            if ask_yesno "Docker service is disabled in Services. Enable it now?"; then
                log "Enabling docker service"
                batocera-services enable docker >/dev/null 2>&1 || true
            else
                show_msg "Docker service must be enabled before container installation."
                return 1
            fi
        fi

        if ! service_started; then
            show_info "Starting Docker service..."
            log "Starting docker service"
            batocera-services start docker >/dev/null 2>&1 || true
            sleep 2
        fi
    fi

    if ! docker info >/dev/null 2>&1; then
        show_msg "Docker daemon is not reachable. Enable/start Docker in System Settings > Services, then retry."
        return 1
    fi

    return 0
}

remove_container_if_exists() {
    local name="$1"

    if docker ps -a --format '{{.Names}}' | grep -Fxq "${name}"; then
        log "Removing existing container ${name}"
        docker rm -f "${name}" >/dev/null 2>&1 || true
    fi
}

find_templates_json() {
    local candidate

    for candidate in \
        "/userdata/system/pro/linux/apps/docker/templates.json" \
        "/userdata/system/apps/docker/templates.json" \
        "/userdata/system/docker/templates.json" \
        "/userdata/system/profork/apps/docker/templates.json" \
        "/apps/docker/templates.json"; do
        if [ -f "${candidate}" ]; then
            echo "${candidate}"
            return 0
        fi
    done

    return 1
}

find_next_windows_dir() {
    local base_dir="/userdata/system/windows"
    local idx=2

    if [ ! -d "${base_dir}" ] || [ -z "$(ls -A "${base_dir}" 2>/dev/null)" ]; then
        echo "${base_dir}"
        return 0
    fi

    while [ -d "${base_dir}${idx}" ] && [ -n "$(ls -A "${base_dir}${idx}" 2>/dev/null)" ]; do
        idx=$((idx + 1))
    done

    echo "${base_dir}${idx}"
}

deploy_portainer() {
    local templates_src=""
    local run_rc=0

    mkdir -p "${DATA_ROOT}/portainer" >/dev/null 2>&1 || true
    remove_container_if_exists portainer
    docker volume create portainer_data >/dev/null 2>&1 || true

    if templates_src="$(find_templates_json)"; then
        cp -f "${templates_src}" "${PORTAINER_TEMPLATE_DST}" >/dev/null 2>&1 || true
        log "Using Portainer templates from ${templates_src}"
    else
        log "No templates.json found; installing Portainer without template override"
    fi

    if [ -f "${PORTAINER_TEMPLATE_DST}" ]; then
        docker run \
            --privileged \
            --net host \
            --ipc host \
            -d \
            --name portainer \
            --restart=always \
            -v /var/run/docker.sock:/var/run/docker.sock \
            -v /media:/media \
            -v portainer_data:/data \
            -v "${PORTAINER_TEMPLATE_DST}:/templates/templates.json:ro" \
            portainer/portainer-ce:latest \
            --templates "file:///templates/templates.json" >/dev/null || run_rc=$?

        if [ "${run_rc}" -ne 0 ]; then
            log "Portainer template flag failed, retrying without --templates"
            remove_container_if_exists portainer
            docker run \
                --privileged \
                --net host \
                --ipc host \
                -d \
                --name portainer \
                --restart=always \
                -v /var/run/docker.sock:/var/run/docker.sock \
                -v /media:/media \
                -v portainer_data:/data \
                -v "${PORTAINER_TEMPLATE_DST}:/templates/templates.json:ro" \
                portainer/portainer-ce:latest >/dev/null || return 1
        fi
    else
        docker run \
            --privileged \
            --net host \
            --ipc host \
            -d \
            --name portainer \
            --restart=always \
            -v /var/run/docker.sock:/var/run/docker.sock \
            -v /media:/media \
            -v portainer_data:/data \
            portainer/portainer-ce:latest >/dev/null || return 1
    fi

    DEPLOY_NOTE="Portainer: https://<batocera-ip>:9443"
    return 0
}

deploy_casa2() {
    local host_port
    host_port="$(find_free_port 8080)"

    mkdir -p /userdata/system/casaos >/dev/null 2>&1 || true
    remove_container_if_exists casa

    docker run -d \
        --name casa \
        -p "${host_port}:8080" \
        -v /userdata/system/casaos:/DATA \
        -v /var/run/docker.sock:/var/run/docker.sock \
        --stop-timeout 60 \
        --restart unless-stopped \
        dockurr/casa >/dev/null || return 1

    DEPLOY_NOTE="CasaOS: http://<batocera-ip>:${host_port}"
    return 0
}

deploy_emby() {
    local port_http port_https tz
    local -a dri_arg=()

    port_http="$(find_free_port 8096)"
    port_https="$(find_free_port 8920)"
    tz="$(get_timezone)"
    if [ -e /dev/dri ]; then
        dri_arg=(--device /dev/dri:/dev/dri)
    fi

    mkdir -p /userdata/system/emby/config /userdata/system/emby/data/tvshows /userdata/system/emby/data/movies
    remove_container_if_exists emby

    docker run -d \
        --name emby \
        -e PUID="$(id -u)" \
        -e PGID="$(id -g)" \
        -e TZ="${tz}" \
        -p "${port_http}:8096" \
        -p "${port_https}:8920" \
        -v /userdata/system/emby/config:/config \
        -v /userdata/system/emby/data/tvshows:/data/tvshows \
        -v /userdata/system/emby/data/movies:/data/movies \
        "${dri_arg[@]}" \
        --restart unless-stopped \
        lscr.io/linuxserver/emby:latest >/dev/null || return 1

    DEPLOY_NOTE="Emby: http://<batocera-ip>:${port_http}"
    return 0
}

