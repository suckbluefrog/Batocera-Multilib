        -p "${port_https}:8920" \
        -p "${port_udp1}:7359/udp" \
        -p "${port_udp2}:1900/udp" \
        -v /userdata/system/jellyfin/config:/config \
        -v /userdata/system/jellyfin/data/tvshows:/data/tvshows \
