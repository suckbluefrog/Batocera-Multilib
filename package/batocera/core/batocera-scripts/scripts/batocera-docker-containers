deploy_systools() {
    local glances_port wetty_port fb_port uid gid

    glances_port="$(find_free_port 61208)"
    wetty_port="$(find_free_port 3000)"
    fb_port="$(find_free_port 8080)"
    uid="$(id -u)"
    gid="$(id -g)"

    mkdir -p /userdata/system/docker_services/filebrowser_data

    remove_container_if_exists glances
    remove_container_if_exists wetty
    remove_container_if_exists filemanager

    docker run -d \
        --name glances \
        --pid host \
        -p "${glances_port}:61208" \
        -v /var/run/docker.sock:/var/run/docker.sock:ro \
        -v /etc/os-release:/etc/os-release:ro \
        --restart unless-stopped \
        nicolargo/glances:latest glances -w >/dev/null || return 1

    docker run -d \
        --name wetty \
        --user "${uid}:${gid}" \
        -p "${wetty_port}:3000" \
        -e SSL=false \
        -e FORCE_SSH=true \
        -e ALLOW_IFRAME=true \
        -v /etc/localtime:/etc/localtime:ro \
        -v /etc/passwd:/etc/passwd:ro \
        -v /etc/group:/etc/group:ro \
        -v /tmp:/tmp \
        --restart unless-stopped \
        wettyoss/wetty:latest >/dev/null || return 1

    docker run -d \
        --name filemanager \
        --user "${uid}:${gid}" \
        -p "${fb_port}:80" \
        -e FB_NOAUTH=true \
        -v /userdata/system/docker_services/filebrowser_data:/config \
        -v /:/srv \
        --restart unless-stopped \
        filebrowser/filebrowser:latest >/dev/null || return 1

    DEPLOY_NOTE="Glances: http://<batocera-ip>:${glances_port} | Wetty: http://<batocera-ip>:${wetty_port}/wetty | Filemanager: http://<batocera-ip>:${fb_port}"
    return 0
}

