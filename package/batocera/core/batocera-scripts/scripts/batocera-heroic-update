#!/bin/bash
set -euo pipefail

roms_dir="/userdata/roms/heroic"
tmp_xml="/tmp/batocera-heroic-update.tmp"
es_server="http://127.0.0.1:1234"
log="/userdata/system/logs/heroic-update.log"

mkdir -p "${roms_dir}" "$(dirname "${log}")"

xml_escape() {
    local value="$1"
    value="${value//&/&amp;}"
    value="${value//</&lt;}"
    value="${value//>/&gt;}"
    value="${value//\"/&quot;}"
    value="${value//\'/&apos;}"
    printf '%s' "${value}"
}

slugify() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

normalize_exec() {
    local line="$1"
    line="${line#Exec=}"
    for token in %f %F %u %U %i %c %k %d %D %n %N %v %m; do
        line="${line//${token}/}"
    done
    printf '%s' "${line}" | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

extract_name() {
    local desktop_file="$1"
    local name
    name="$(sed -n 's/^Name=//p' "${desktop_file}" | head -n1 || true)"
    if [[ -z "${name}" ]]; then
        name="$(sed -n 's/^Name\\[[^]]*\\]=//p' "${desktop_file}" | head -n1 || true)"
    fi
    printf '%s' "${name}"
}

write_game_launcher() {
    local script_path="$1"
    local exec_line="$2"
    local escaped_exec
    escaped_exec="$(printf '%q' "${exec_line}")"

    cat > "${script_path}" <<EOF
#!/bin/bash
set -euo pipefail
batocera-mouse show
trap 'batocera-mouse hide' EXIT
exec_line=${escaped_exec}

# Keep native Heroic state in /userdata/saves/heroic.
if [[ "\${exec_line}" != flatpak* ]]; then
    export HOME="/userdata/saves/heroic"
    export XDG_CONFIG_HOME="\${HOME}/.config"
    export XDG_DATA_HOME="\${HOME}/.local/share"
    export XDG_CACHE_HOME="\${HOME}/.cache"
    mkdir -p "\${XDG_CONFIG_HOME}" "\${XDG_DATA_HOME}" "\${XDG_CACHE_HOME}"
fi

bash -lc "\${exec_line} \${BATOCERA_HEROIC_EXTRA_ARGS:-}"
EOF
    chmod 0755 "${script_path}"
}

write_launcher_entry() {
    local script_path="$1"
    cat > "${script_path}" <<'EOF'
#!/bin/bash
set -euo pipefail
batocera-mouse show
trap 'batocera-mouse hide' EXIT

extra_args=()
if [[ -n "${BATOCERA_HEROIC_EXTRA_ARGS:-}" ]]; then
    read -r -a extra_args <<< "${BATOCERA_HEROIC_EXTRA_ARGS}"
fi

if command -v heroic >/dev/null 2>&1; then
    export HOME="/userdata/saves/heroic"
    export XDG_CONFIG_HOME="${HOME}/.config"
    export XDG_DATA_HOME="${HOME}/.local/share"
    export XDG_CACHE_HOME="${HOME}/.cache"
    mkdir -p "${XDG_CONFIG_HOME}" "${XDG_DATA_HOME}" "${XDG_CACHE_HOME}"
    exec heroic "${extra_args[@]}"
elif command -v flatpak >/dev/null 2>&1 && flatpak info com.heroicgameslauncher.hgl >/dev/null 2>&1; then
    exec flatpak run com.heroicgameslauncher.hgl "${extra_args[@]}"
fi

echo "Heroic runtime not found (expected native heroic or flatpak com.heroicgameslauncher.hgl)." >&2
sleep 2
exit 1
EOF
    chmod 0755 "${script_path}"
}

es_add_game_begin() {
    echo "<gameList>" > "${tmp_xml}"
}

es_add_game() {
    local game_path="$1"
    local game_name="$2"
    cat >> "${tmp_xml}" <<EOF
<game>
  <path>$(xml_escape "${game_path}")</path>
  <name>$(xml_escape "${game_name}")</name>
  <desc></desc>
  <rating></rating>
  <releasedate></releasedate>
  <developer></developer>
  <publisher></publisher>
  <genre></genre>
  <players></players>
  <image></image>
  <manual></manual>
  <video></video>
</game>
EOF
}

es_add_game_end() {
    echo "</gameList>" >> "${tmp_xml}"
    curl -s -X POST \
        -H "Content-type: application/x-www-form-urlencoded" \
        -H "Accept: text/plain" \
        "${es_server}/addgames/heroic" \
        -d @"${tmp_xml}" > /dev/null || true
}

echo "Refreshing Heroic launchers from desktop entries." >> "${log}"
find "${roms_dir}" -maxdepth 1 -type f -name 'heroic-auto-*.sh' -delete

es_add_game_begin

declare -a desktop_files=()
for dir in \
    "/userdata/system/.local/share/applications" \
    "/userdata/system/.local/share/flatpak/exports/share/applications" \
    "/userdata/system/Desktop" \
    "/userdata/saves/heroic/.local/share/applications" \
    "/userdata/saves/heroic/.local/share/flatpak/exports/share/applications" \
    "/userdata/saves/heroic/Desktop" \
    "${HOME:-/userdata/system}/.local/share/applications" \
    "${HOME:-/userdata/system}/.local/share/flatpak/exports/share/applications" \
    "/var/lib/flatpak/exports/share/applications" \
    "${HOME:-/userdata/system}/Desktop"
do
    if [[ -d "${dir}" ]]; then
        while IFS= read -r -d '' file; do
            desktop_files+=("${file}")
        done < <(find "${dir}" -maxdepth 1 -type f -name '*.desktop' -print0 2>/dev/null)
    fi
done

has_heroic_uri=0
for desktop_file in "${desktop_files[@]}"; do
    exec_line="$(sed -n 's/^Exec=//p' "${desktop_file}" | head -n1 || true)"
    exec_line="$(normalize_exec "${exec_line}")"
    if [[ "${exec_line}" == *"heroic://"* ]]; then
        has_heroic_uri=1
        break
    fi
done

declare -A seen=()
game_count=0
for desktop_file in "${desktop_files[@]}"; do
    name="$(extract_name "${desktop_file}")"
    exec_line="$(sed -n 's/^Exec=//p' "${desktop_file}" | head -n1 || true)"
    exec_line="$(normalize_exec "${exec_line}")"

    [[ -z "${name}" || -z "${exec_line}" ]] && continue
    exec_lower="${exec_line,,}"

    if [[ "${has_heroic_uri}" -eq 1 ]]; then
        [[ "${exec_line}" == *"heroic://"* ]] || continue
    else
        [[ "${exec_lower}" == *"heroic"* ]] || continue
    fi

    slug="$(slugify "${name}")"
    [[ -z "${slug}" ]] && continue
    [[ -n "${seen["${slug}"]+x}" ]] && continue
    seen["${slug}"]=1

    script_name="heroic-auto-${slug}.sh"
    script_path="${roms_dir}/${script_name}"
    write_game_launcher "${script_path}" "${exec_line}"
    es_add_game "./${script_name}" "${name}"
    game_count=$((game_count + 1))
done

# Fallback for environments where Heroic logs "shortcut created" but no .desktop
# files end up on disk: derive launchers from Legendary installed metadata.
if [[ "${game_count}" -eq 0 ]]; then
    installed_json="/userdata/saves/heroic/.config/heroic/legendaryConfig/legendary/installed.json"
    if [[ -f "${installed_json}" ]]; then
        while IFS=$'\t' read -r app_name title; do
            [[ -z "${app_name}" || -z "${title}" ]] && continue

            slug="$(slugify "${title}")"
            [[ -z "${slug}" ]] && continue
            [[ -n "${seen["${slug}"]+x}" ]] && continue
            seen["${slug}"]=1

            script_name="heroic-auto-${slug}.sh"
            script_path="${roms_dir}/${script_name}"
            exec_line="heroic \"heroic://launch/${app_name}\""
            write_game_launcher "${script_path}" "${exec_line}"
            es_add_game "./${script_name}" "${title}"
            game_count=$((game_count + 1))
        done < <(python3 - "${installed_json}" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    data = {}

if isinstance(data, dict):
    for app_name, meta in data.items():
        if not isinstance(meta, dict):
            continue
        title = str(meta.get("title") or app_name).strip()
        app_name = str(app_name).strip()
        if app_name and title:
            print(f"{app_name}\t{title}")
PY
)
    fi
fi

es_add_game_end
echo "Heroic launcher update complete: ${game_count} game launcher(s) generated." >> "${log}"
