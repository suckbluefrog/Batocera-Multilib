#!/bin/sh
# SPDX-FileCopyrightText: 2026 suckbluefrog
set -eu

LOG="/userdata/system/logs/steam.log"
HOTKEY_DIR="/userdata/system/configs/hotkeygen"
ACTIVE_MAP="${HOTKEY_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"
COMMON_CONTEXT="${HOTKEY_DIR}/common_context.ally.conf"
SYSTEM_DIR="/usr/share/hotkeygen"
ES_MAP="${SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping.es"
DEFAULT_MAP="${SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"

hotkeygen_permanent_running() {
    pgrep -f '(^|[[:space:]])(/usr/bin/)?hotkeygen([[:space:]].*)?--permanent([[:space:]]|$)' >/dev/null 2>&1
}

allyhotkeys_enabled() {
    [ -f "${COMMON_CONTEXT}" ]
}

restore_ally_es_map() {
    src=""

    if ! allyhotkeys_enabled; then
        return 1
    fi

    mkdir -p "${HOTKEY_DIR}" 2>/dev/null || true
    for src in "${ES_MAP}" "${DEFAULT_MAP}"; do
        if [ -f "${src}" ]; then
            cp -f "${src}" "${ACTIVE_MAP}" 2>/dev/null || true
            return 0
        fi
    done

    return 1
}

start() {
    mkdir -p "$(dirname "${LOG}")" 2>/dev/null || true

    if restore_ally_es_map; then
        echo "Steam hotkeys boot-reset: restored ES profile" >> "${LOG}"
    fi

    if command -v hotkeygen >/dev/null 2>&1; then
        /usr/bin/hotkeygen --default-context >/dev/null 2>&1 || true
        if hotkeygen_permanent_running; then
            /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
        fi
    fi
}

case "${1:-}" in
    start|restart)
        start
        ;;
    stop)
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}" >&2
        exit 1
        ;;
esac
