#!/bin/bash
# SPDX-FileCopyrightText: 2026 suckbluefrog
set -euo pipefail

log="/userdata/system/logs/steam-desktop-switch.log"
mkdir -p "$(dirname "${log}")"
lock="/var/run/batocera-steam-desktop-switch.lock"
steam_session_pattern='(^|/)batocera-steam-session([[:space:]]|$)'
desktop_launcher="/usr/bin/batocera-steam-desktop-launcher"
desktop_launcher_pattern='(^|/)batocera-steam-desktop-launcher([[:space:]]|$)'
ALLY_HOTKEY_DIR="/userdata/system/configs/hotkeygen"
ALLY_ACTIVE_MAP="${ALLY_HOTKEY_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"
ALLY_COMMON_CONTEXT="${ALLY_HOTKEY_DIR}/common_context.ally.conf"
ALLY_SYSTEM_DIR="/usr/share/hotkeygen"
ALLY_ES_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping.es"
ALLY_DEFAULT_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"
HARD_KILL_ON_SWITCH="${BATOCERA_STEAM_DESKTOP_SWITCH_HARD_KILL:-1}"
echo "[$(date +%F\ %T)] switch-to-desktop: process start" >> "${log}"

if command -v flock >/dev/null 2>&1; then
    exec 9>"${lock}"
    if ! flock -n 9; then
        echo "[$(date +%F\ %T)] switch-to-desktop: already running, skipping duplicate request" >> "${log}"
        exit 0
    fi
fi

steam_stack_alive() {
    pgrep -x batocera-steam >/dev/null 2>&1 || \
    pgrep -f "${steam_session_pattern}" >/dev/null 2>&1 || \
    pgrep -x steam >/dev/null 2>&1 || \
    pgrep -x steamwebhelper >/dev/null 2>&1 || \
    pgrep -x gamescope >/dev/null 2>&1 || \
    pgrep -x gamescopereaper >/dev/null 2>&1 || \
    pgrep -x gamescopestream >/dev/null 2>&1 || \
    pgrep -x gamescopectl >/dev/null 2>&1 || \
    pgrep -f '/userdata/system/homebrew/services/PluginLoader' >/dev/null 2>&1 || \
    pgrep -f '/userdata/system/steam/steam.sh|/usr/share/steam/bin_steam.sh|emulatorlauncher.*-system steam|Steam GamepadUI\.steam|Steam Desktop\.steam' >/dev/null 2>&1
}

hotkeys_restored=0

hotkeygen_permanent_running() {
    pgrep -f '(^|[[:space:]])(/usr/bin/)?hotkeygen([[:space:]].*)?--permanent([[:space:]]|$)' >/dev/null 2>&1
}

allyhotkeys_enabled() {
    [ -f "${ALLY_COMMON_CONTEXT}" ]
}

recover_hotkeys() {
    local src

    if [ "${hotkeys_restored}" = "1" ]; then
        return
    fi

    if allyhotkeys_enabled; then
        mkdir -p "${ALLY_HOTKEY_DIR}" 2>/dev/null || true
        for src in "${ALLY_ES_MAP}" "${ALLY_DEFAULT_MAP}"; do
            if [ -f "${src}" ]; then
                cp -f "${src}" "${ALLY_ACTIVE_MAP}" 2>/dev/null || true
                break
            fi
        done
    fi

    if command -v hotkeygen >/dev/null 2>&1; then
        if ! hotkeygen_permanent_running && [ -x /etc/init.d/S90hotkeygen ]; then
            /etc/init.d/S90hotkeygen start >/dev/null 2>&1 || true
        fi
        /usr/bin/hotkeygen --default-context >/dev/null 2>&1 || true
        /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
    fi

    hotkeys_restored=1
}

recover_hotkeys_force() {
    hotkeys_restored=0
    recover_hotkeys || true
}

cleanup_on_exit() {
    recover_hotkeys || true
}

trap cleanup_on_exit EXIT TERM INT

wait_for_stack_exit() {
    local max_tries="${1:-40}"
    local i
    for i in $(seq 1 "${max_tries}"); do
        if ! steam_stack_alive; then
            return 0
        fi
        sleep 0.2
    done
    return 1
}

start_desktop_launcher() {
    if [[ ! -x "${desktop_launcher}" ]]; then
        echo "[$(date +%F\ %T)] switch-to-desktop: desktop launcher missing or not executable: ${desktop_launcher}" >> "${log}"
        return 1
    fi

    if pgrep -f "${desktop_launcher_pattern}" >/dev/null 2>&1; then
        echo "[$(date +%F\ %T)] switch-to-desktop: detached desktop launcher already running" >> "${log}"
        return 0
    fi

    if command -v setsid >/dev/null 2>&1; then
        setsid "${desktop_launcher}" 9>&- >> "${log}" 2>&1 < /dev/null &
    else
        nohup "${desktop_launcher}" 9>&- >> "${log}" 2>&1 &
    fi

    sleep 0.1
    if pgrep -f "${desktop_launcher_pattern}" >/dev/null 2>&1; then
        echo "[$(date +%F\ %T)] switch-to-desktop: detached desktop launcher queued" >> "${log}"
        return 0
    fi

    echo "[$(date +%F\ %T)] switch-to-desktop: detached desktop launcher failed to start" >> "${log}"
    return 1
}

terminate_steam_stack() {
    if [[ "${HARD_KILL_ON_SWITCH}" != "0" ]]; then
        echo "[$(date +%F\ %T)] switch-to-desktop: using immediate hard-kill teardown" >> "${log}"
        pkill -KILL -x batocera-steam >/dev/null 2>&1 || true
        pkill -KILL -f "${steam_session_pattern}" >/dev/null 2>&1 || true
        pkill -KILL -x steam >/dev/null 2>&1 || true
        pkill -KILL -x steamwebhelper >/dev/null 2>&1 || true
        pkill -KILL -x gamescope >/dev/null 2>&1 || true
        pkill -KILL -x gamescopereaper >/dev/null 2>&1 || true
        pkill -KILL -x gamescopestream >/dev/null 2>&1 || true
        pkill -KILL -x gamescopectl >/dev/null 2>&1 || true
        pkill -KILL -x steam-runtime-supervisor >/dev/null 2>&1 || true
        pkill -KILL -f '/userdata/system/homebrew/services/PluginLoader' >/dev/null 2>&1 || true
        pkill -KILL -f 'pressure-vessel' >/dev/null 2>&1 || true
        pkill -KILL -f '/userdata/system/steam/steam.sh|/usr/share/steam/bin_steam.sh|emulatorlauncher.*-system steam|Steam GamepadUI\.steam|Steam Desktop\.steam' >/dev/null 2>&1 || true

        if command -v killall >/dev/null 2>&1; then
            killall -q -9 batocera-steam steam steamwebhelper gamescope gamescopereaper gamescopestream gamescopectl steam-runtime-supervisor >/dev/null 2>&1 || true
        fi

        wait_for_stack_exit 15 || true
        return
    fi

    pkill -TERM -x batocera-steam >/dev/null 2>&1 || true
    pkill -TERM -f "${steam_session_pattern}" >/dev/null 2>&1 || true
    pkill -TERM -x steam >/dev/null 2>&1 || true
    pkill -TERM -x steamwebhelper >/dev/null 2>&1 || true
    pkill -TERM -x gamescope >/dev/null 2>&1 || true
    pkill -TERM -x gamescopereaper >/dev/null 2>&1 || true
    pkill -TERM -x gamescopestream >/dev/null 2>&1 || true
    pkill -TERM -x gamescopectl >/dev/null 2>&1 || true
    pkill -TERM -x steam-runtime-supervisor >/dev/null 2>&1 || true
    pkill -TERM -f '/userdata/system/homebrew/services/PluginLoader' >/dev/null 2>&1 || true
    pkill -TERM -f 'pressure-vessel' >/dev/null 2>&1 || true
    pkill -TERM -f '/userdata/system/steam/steam.sh|/usr/share/steam/bin_steam.sh|emulatorlauncher.*-system steam|Steam GamepadUI\.steam|Steam Desktop\.steam' >/dev/null 2>&1 || true

    if wait_for_stack_exit 40; then
        return
    fi

    pkill -KILL -x batocera-steam >/dev/null 2>&1 || true
    pkill -KILL -f "${steam_session_pattern}" >/dev/null 2>&1 || true
    pkill -KILL -x steam >/dev/null 2>&1 || true
    pkill -KILL -x steamwebhelper >/dev/null 2>&1 || true
    pkill -KILL -x gamescope >/dev/null 2>&1 || true
    pkill -KILL -x gamescopereaper >/dev/null 2>&1 || true
    pkill -KILL -x gamescopestream >/dev/null 2>&1 || true
    pkill -KILL -x gamescopectl >/dev/null 2>&1 || true
    pkill -KILL -x steam-runtime-supervisor >/dev/null 2>&1 || true
    pkill -KILL -f '/userdata/system/homebrew/services/PluginLoader' >/dev/null 2>&1 || true
    pkill -KILL -f 'pressure-vessel' >/dev/null 2>&1 || true
    pkill -KILL -f '/userdata/system/steam/steam.sh|/usr/share/steam/bin_steam.sh|emulatorlauncher.*-system steam|Steam GamepadUI\.steam|Steam Desktop\.steam' >/dev/null 2>&1 || true

    if command -v killall >/dev/null 2>&1; then
        killall -q -9 steam steamwebhelper gamescope gamescopereaper gamescopestream gamescopectl steam-runtime-supervisor >/dev/null 2>&1 || true
    fi

    wait_for_stack_exit 30 || true
}

echo "[$(date +%F\ %T)] switch-to-desktop: invoked" >> "${log}"
launcher_started=0
if start_desktop_launcher; then
    launcher_started=1
fi
echo "[$(date +%F\ %T)] switch-to-desktop: stopping steam stack" >> "${log}"
recover_hotkeys_force
terminate_steam_stack

if steam_stack_alive; then
    echo "[$(date +%F\ %T)] switch-to-desktop: steam stack still alive after kill attempts" >> "${log}"
fi

if [[ "${launcher_started}" -eq 1 ]]; then
    echo "[$(date +%F\ %T)] switch-to-desktop: handoff to detached desktop launcher complete" >> "${log}"
    exit 0
fi

echo "[$(date +%F\ %T)] switch-to-desktop: detached launch failed, running desktop launcher inline" >> "${log}"

if ! "${desktop_launcher}" >> "${log}" 2>&1; then
    echo "[$(date +%F\ %T)] switch-to-desktop: inline desktop launcher failed" >> "${log}"
    recover_hotkeys_force
    exit 1
fi

recover_hotkeys_force
sleep 0.6
recover_hotkeys_force
echo "[$(date +%F\ %T)] switch-to-desktop: inline desktop launcher complete" >> "${log}"
