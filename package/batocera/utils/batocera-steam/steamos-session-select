#!/bin/bash
# SPDX-FileCopyrightText: 2026 suckbluefrog
set -euo pipefail

log="/userdata/system/logs/steam.log"
mkdir -p "$(dirname "$log")"
lock="/var/run/steamos-session-select.lock"
steam_session_pattern='(^|/)batocera-steam-session([[:space:]]|$)'
ASYNC="${STEAMOS_SESSION_SELECT_ASYNC:-0}"
ALLY_HOTKEY_DIR="/userdata/system/configs/hotkeygen"
ALLY_ACTIVE_MAP="${ALLY_HOTKEY_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"
ALLY_COMMON_CONTEXT="${ALLY_HOTKEY_DIR}/common_context.ally.conf"
ALLY_SYSTEM_DIR="/usr/share/hotkeygen"
ALLY_ES_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping.es"
ALLY_DEFAULT_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"

allyhotkeys_enabled() {
    [[ -f "${ALLY_COMMON_CONTEXT}" ]]
}

request="${1:-}"
echo "SteamOS session switch requested: ${request}" >> "${log}"

if [[ "${ASYNC}" != "1" ]] && command -v flock >/dev/null 2>&1; then
    exec 9>"${lock}"
    if ! flock -n 9; then
        echo "SteamOS session switch skipped (already running): ${request}" >> "${log}"
        exit 0
    fi
fi

run_detached() {
    if command -v setsid >/dev/null 2>&1; then
        setsid "$@" 9>&- </dev/null >/dev/null 2>&1 &
    else
        nohup "$@" 9>&- </dev/null >/dev/null 2>&1 &
    fi
}

run_es_cmd() {
    if command -v timeout >/dev/null 2>&1; then
        timeout 15 "$@" >/dev/null 2>&1
    else
        "$@" >/dev/null 2>&1
    fi
}

resume_es() {
    local i

    if pgrep -x emulationstation >/dev/null 2>&1 || pgrep -x labwc >/dev/null 2>&1; then
        return 0
    fi

    if [[ -x /etc/init.d/S31emulationstation ]]; then
        echo "Restoring EmulationStation via restart/start" >> "${log}"
        sleep 2
        run_es_cmd /etc/init.d/S31emulationstation restart || \
            run_es_cmd /etc/init.d/S31emulationstation start || true
        for i in $(seq 1 30); do
            if pgrep -x emulationstation >/dev/null 2>&1 || pgrep -x labwc >/dev/null 2>&1; then
                return 0
            fi
            sleep 0.2
        done
        echo "EmulationStation did not return after restart/start" >> "${log}"
    fi

    if ! pgrep -x emulationstation >/dev/null 2>&1; then
        emulationstation >/dev/null 2>&1 &
    fi
}

steam_stack_alive() {
    pgrep -x batocera-steam >/dev/null 2>&1 || \
    pgrep -f "${steam_session_pattern}" >/dev/null 2>&1 || \
    pgrep -x steam >/dev/null 2>&1 || \
    pgrep -x steamwebhelper >/dev/null 2>&1 || \
    pgrep -x gamescope >/dev/null 2>&1 || \
    pgrep -x gamescopereaper >/dev/null 2>&1 || \
    pgrep -x gamescopestream >/dev/null 2>&1 || \
    pgrep -x gamescopectl >/dev/null 2>&1 || \
    pgrep -f '/userdata/system/homebrew/services/PluginLoader' >/dev/null 2>&1 || \
    pgrep -f '/userdata/system/steam/steam.sh|/usr/share/steam/bin_steam.sh|emulatorlauncher.*-system steam|Steam GamepadUI\.steam|Steam Desktop\.steam' >/dev/null 2>&1
}

terminate_steam_stack() {
    echo "Stopping Steam/gamescope process stack" >> "${log}"

    # Hard-kill first for reliability on this build.
    if command -v killall >/dev/null 2>&1; then
        killall -q -9 steam steamwebhelper steam-runtime-supervisor \
            gamescope gamescopereaper gamescopestream gamescopectl PluginLoader \
            >/dev/null 2>&1 || true
    fi
    pkill -KILL -x batocera-steam >/dev/null 2>&1 || true
    pkill -KILL -f "${steam_session_pattern}" >/dev/null 2>&1 || true
    pkill -KILL -f 'pressure-vessel' >/dev/null 2>&1 || true
    pkill -KILL -f '/userdata/system/steam/steam.sh|/usr/share/steam/bin_steam.sh|emulatorlauncher.*-system steam|Steam GamepadUI\.steam|Steam Desktop\.steam' >/dev/null 2>&1 || true

    for _ in $(seq 1 20); do
        if ! steam_stack_alive; then
            return
        fi
        sleep 0.2
    done

    if steam_stack_alive; then
        echo "Steam stack still alive after hard kill:" >> "${log}"
        pgrep -af 'steam|steamwebhelper|gamescope|batocera-steam' >> "${log}" || true
    fi
}

hotkeygen_permanent_running() {
    pgrep -f '(^|[[:space:]])(/usr/bin/)?hotkeygen([[:space:]].*)?--permanent([[:space:]]|$)' >/dev/null 2>&1
}

restore_ally_hotkeys_es() {
    local src

    if ! allyhotkeys_enabled; then
        return 0
    fi

    mkdir -p "${ALLY_HOTKEY_DIR}" 2>/dev/null || true
    for src in "${ALLY_ES_MAP}" "${ALLY_DEFAULT_MAP}"; do
        if [[ -f "${src}" ]]; then
            cp -f "${src}" "${ALLY_ACTIVE_MAP}" 2>/dev/null || true
            break
        fi
    done

    if command -v hotkeygen >/dev/null 2>&1; then
        if ! hotkeygen_permanent_running && [[ -x /etc/init.d/S90hotkeygen ]]; then
            /etc/init.d/S90hotkeygen start >/dev/null 2>&1 || true
        fi
        /usr/bin/hotkeygen --default-context >/dev/null 2>&1 || true
        /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
    fi
}

case "${request}" in
    plasma|desktop)
        if [[ "${ASYNC}" != "1" ]]; then
            echo "Session switch requested: ${request} (async detach)" >> "${log}"
            STEAMOS_SESSION_SELECT_ASYNC=1 run_detached "$0" "${request}"
            exit 0
        fi

        echo "Exiting Steam session and returning to EmulationStation" >> "${log}"
        restore_ally_hotkeys_es
        terminate_steam_stack
        restore_ally_hotkeys_es
        resume_es
        restore_ally_hotkeys_es
        ;;
    gamescope|gamemode)
        echo "Launching Steam session" >> "${log}"
        /usr/bin/batocera-steam >/dev/null 2>&1 &
        ;;
    *)
        echo "Unknown session target: ${request}" >> "${log}"
        exit 1
        ;;
esac
