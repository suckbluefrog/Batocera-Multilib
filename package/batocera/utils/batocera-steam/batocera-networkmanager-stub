def _dict_changes(old, new):
    if old is None or new is None:
        return {}
    changed = {}
    for key, value in new.items():
        if old.get(key) != value:
            changed[key] = value
    return changed


def periodic_refresh(shim, root_obj, manager_obj, settings_obj, device_obj, active_obj, ip4_obj, ap_objects, bus):
    old_manager = shim.manager_properties()
    old_settings = shim.settings_properties()
    old_device = shim.device_properties()
    old_wireless = shim.wireless_properties()
    old_active = shim.active_properties()
    old_ip4 = shim.ip4_properties()
    old_ap_paths = set(shim.access_point_paths())
    old_ap_props = {p: shim.access_point_properties(p) for p in old_ap_paths}

    shim.refresh()

    new_manager = shim.manager_properties()
    new_settings = shim.settings_properties()
    new_device = shim.device_properties()
    new_wireless = shim.wireless_properties()
    new_active = shim.active_properties()
    new_ip4 = shim.ip4_properties()
    new_ap_paths = set(shim.access_point_paths())

    changed_manager = _dict_changes(old_manager, new_manager)
    if changed_manager:
        manager_obj.PropertiesChanged("org.freedesktop.NetworkManager", changed_manager, [])

    changed_settings = _dict_changes(old_settings, new_settings)
    if changed_settings:
        settings_obj.PropertiesChanged("org.freedesktop.NetworkManager.Settings", changed_settings, [])

    if old_device is not None and new_device is not None:
        changed_device = _dict_changes(old_device, new_device)
        if changed_device:
            device_obj.PropertiesChanged("org.freedesktop.NetworkManager.Device", changed_device, [])

    if old_wireless is not None and new_wireless is not None:
        changed_wireless = _dict_changes(old_wireless, new_wireless)
        if changed_wireless:
            device_obj.PropertiesChanged("org.freedesktop.NetworkManager.Device.Wireless", changed_wireless, [])

    if old_active is not None and new_active is not None:
        changed_active = _dict_changes(old_active, new_active)
        if changed_active:
            active_obj.PropertiesChanged("org.freedesktop.NetworkManager.Connection.Active", changed_active, [])

    if old_ip4 is not None and new_ip4 is not None:
        changed_ip4 = _dict_changes(old_ip4, new_ip4)
        if changed_ip4:
            ip4_obj.PropertiesChanged("org.freedesktop.NetworkManager.IP4Config", changed_ip4, [])

    added_paths = new_ap_paths - old_ap_paths
    removed_paths = old_ap_paths - new_ap_paths

    for path in sorted(added_paths):
        ap_obj = AccessPointObject(bus, shim, path)
        ap_objects[path] = ap_obj
        props = shim.access_point_properties(path)
        if props is not None:
            root_obj.InterfacesAdded(dbus.ObjectPath(path), {"org.freedesktop.NetworkManager.AccessPoint": props})
            device_obj.AccessPointAdded(dbus.ObjectPath(path))

    for path in sorted(removed_paths):
        ap_obj = ap_objects.pop(path, None)
        if ap_obj is not None:
            try:
                ap_obj.remove_from_connection()
            except Exception:
                pass
        root_obj.InterfacesRemoved(dbus.ObjectPath(path), ["org.freedesktop.NetworkManager.AccessPoint"])
        device_obj.AccessPointRemoved(dbus.ObjectPath(path))

    for path in sorted(new_ap_paths & old_ap_paths):
        old_props = old_ap_props.get(path)
        new_props = shim.access_point_properties(path)
        if old_props is None or new_props is None:
            continue
        changed_ap = _dict_changes(old_props, new_props)
        if changed_ap and path in ap_objects:
            ap_objects[path].PropertiesChanged("org.freedesktop.NetworkManager.AccessPoint", changed_ap, [])

    return True


def main() -> int:
    try:
        ensure_system_bus_env()
        dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)
        bus = dbus.SystemBus()
        result = bus.request_name(BUS_NAME, dbus.bus.NAME_FLAG_DO_NOT_QUEUE)
        if result != dbus.bus.REQUEST_NAME_REPLY_PRIMARY_OWNER:
            log(f"cannot own {BUS_NAME}, result={result}")
            return 0

        shim = NetworkManagerShim(bus)
        manager_obj = ManagerObject(bus, shim)
        settings_obj = SettingsObject(bus, shim)
        device_obj = DeviceObject(bus, shim)
        active_obj = ActiveConnectionObject(bus, shim)
        ip4_obj = IP4ConfigObject(bus, shim)
        root_obj = RootObjectManager(bus, shim)

        ap_objects = {}
        for path in shim.access_point_paths():
            ap_objects[path] = AccessPointObject(bus, shim, path)

        GLib.timeout_add_seconds(
            5,
            periodic_refresh,
            shim,
            root_obj,
            manager_obj,
            settings_obj,
            device_obj,
            active_obj,
            ip4_obj,
            ap_objects,
            bus,
        )

        log("NetworkManager compatibility shim running")
        GLib.MainLoop().run()
        return 0
    except Exception as exc:
        log(f"NetworkManager compatibility shim failed: {exc}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
