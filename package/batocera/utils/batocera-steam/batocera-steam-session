set -euo pipefail

log="/userdata/system/logs/steam.log"
mkdir -p "$(dirname "$log")"
if [[ -f "${log}" ]]; then
    log_size="$(wc -c < "${log}" 2>/dev/null || echo 0)"
    if [[ "${log_size}" =~ ^[0-9]+$ ]] && (( log_size > 5242880 )); then
        mv -f "${log}" "${log}.1"
    fi
fi

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 <steam command> [args...]" >&2
    exit 1
fi

export STEAM_DECK=1
export STEAMOS=1
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=gamescope
export HOME="/userdata/system"
export XDG_DATA_HOME="${HOME}/.local/share"
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_CACHE_HOME="${HOME}/.cache"
STEAM_FIRST_RUN_PENDING_STAMP="/userdata/system/.steam-first-run-pending"
STEAM_FIRST_RUN_WIFI_STAMP="/userdata/system/.steam-first-run-wifi-pending"
STEAM_FIRST_RUN_PENDING=0
ALLY_HOTKEY_DIR="/userdata/system/configs/hotkeygen"
ALLY_ACTIVE_MAP="${ALLY_HOTKEY_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"
ALLY_COMMON_CONTEXT="${ALLY_HOTKEY_DIR}/common_context.ally.conf"
ALLY_SYSTEM_DIR="/usr/share/hotkeygen"
ALLY_ES_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping.es"
ALLY_STEAM_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping.steam"
ALLY_DEFAULT_MAP="${ALLY_SYSTEM_DIR}/ASUS_ROG_Ally_Config-b05-1abe.mapping"

allyhotkeys_enabled() {
    [[ -f "${ALLY_COMMON_CONTEXT}" ]]
}

run_ally_hotkey_hook() {
    local event="$1"
    if allyhotkeys_enabled; then
        apply_ally_hotkey_map_for_event "${event}" || true
        return 0
    fi
    return 1
}

hotkeygen_permanent_running() {
    pgrep -f '(^|[[:space:]])(/usr/bin/)?hotkeygen([[:space:]].*)?--permanent([[:space:]]|$)' >/dev/null 2>&1
}

ensure_hotkeygen_started() {
    if command -v hotkeygen >/dev/null 2>&1; then
        if ! hotkeygen_permanent_running && [ -x /etc/init.d/S90hotkeygen ]; then
            /etc/init.d/S90hotkeygen start >/dev/null 2>&1 || true
        fi
    fi
}

apply_ally_hotkey_map() {
    local profile="$1"
    local src=""

    mkdir -p "${ALLY_HOTKEY_DIR}" 2>/dev/null || true

    if ! allyhotkeys_enabled; then
        echo "Steam hotkeys: allyhotkeys service not enabled; skipping profile '${profile}'" >> "${log}"
        return 0
    fi

    case "${profile}" in
        steam)
            for src in "${ALLY_STEAM_MAP}"; do
                if [[ -f "${src}" ]]; then
                    cp -f "${src}" "${ALLY_ACTIVE_MAP}" 2>/dev/null || true
                    ensure_hotkeygen_started
                    /usr/bin/hotkeygen --new-context steam '{}' >/dev/null 2>&1 || true
                    /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
                    echo "Steam hotkeys: applied steam profile from ${src}" >> "${log}"
                    return 0
                fi
            done
            ;;
        es)
            for src in "${ALLY_ES_MAP}" "${ALLY_DEFAULT_MAP}"; do
                if [[ -f "${src}" ]]; then
                    cp -f "${src}" "${ALLY_ACTIVE_MAP}" 2>/dev/null || true
                    ensure_hotkeygen_started
                    /usr/bin/hotkeygen --default-context >/dev/null 2>&1 || true
                    /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
                    echo "Steam hotkeys: applied ES profile from ${src}" >> "${log}"
                    return 0
                fi
            done
            ;;
    esac

    echo "Steam hotkeys: missing profile '${profile}' mapping" >> "${log}"
    return 1
}

apply_ally_hotkey_map_for_event() {
    local event="$1"

    case "${event}" in
        gameStart)
            apply_ally_hotkey_map steam
            ;;
        gameStop)
            apply_ally_hotkey_map es
            ;;
        *)
            return 0
            ;;
    esac
}

recover_hotkeys() {
    if command -v hotkeygen >/dev/null 2>&1; then
        if ! hotkeygen_permanent_running && [ -x /etc/init.d/S90hotkeygen ]; then
            /etc/init.d/S90hotkeygen start >/dev/null 2>&1 || true
        fi
        /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
    fi
}

steam_runtime_active() {
    pgrep -x gamescope >/dev/null 2>&1 || \
    pgrep -x gamescopereaper >/dev/null 2>&1 || \
    pgrep -x gamescopestream >/dev/null 2>&1 || \
    pgrep -x gamescopectl >/dev/null 2>&1 || \
    pgrep -x steam >/dev/null 2>&1 || \
    pgrep -x steamwebhelper >/dev/null 2>&1
}

reassert_ally_steam_hotkeys_later() {
    local delay
    local -a retry_delays=(1 2 4)

    if [[ "${BATOCERA_STEAM_REASSERT_HOTKEYS:-1}" == "0" ]]; then
        return
    fi

    (
        for delay in "${retry_delays[@]}"; do
            sleep "${delay}"
            if ! steam_runtime_active; then
                exit 0
            fi
            apply_ally_hotkey_map steam || true
            echo "Steam hotkeys: reasserted steam profile after ${delay}s" >> "${log}"
        done
    ) &
}

cleanup_hotkeys_on_exit() {
    # "Switch to Desktop" kills the original session outside configgen's normal cleanup path.
    # Restore an explicit default context and ES profile when that happens.
    run_ally_hotkey_hook gameStop || true
    if command -v hotkeygen >/dev/null 2>&1; then
        if ! hotkeygen_permanent_running && [ -x /etc/init.d/S90hotkeygen ]; then
            /etc/init.d/S90hotkeygen start >/dev/null 2>&1 || true
        fi
        /usr/bin/hotkeygen --default-context >/dev/null 2>&1 || true
        /usr/bin/hotkeygen --reload >/dev/null 2>&1 || true
    fi
}

cleanup_hotkeys_and_forward() {
    cleanup_hotkeys_on_exit || true
}

trap cleanup_hotkeys_and_forward EXIT TERM INT

if [[ "${BATOCERA_STEAM_FIRST_RUN:-0}" == "1" ]] || [[ -f "${STEAM_FIRST_RUN_PENDING_STAMP}" ]] || [[ -f "${STEAM_FIRST_RUN_WIFI_STAMP}" ]]; then
    STEAM_FIRST_RUN_PENDING=1
fi

has_network() {
    if command -v ip >/dev/null 2>&1; then
        if ! ip route get 1.1.1.1 >/dev/null 2>&1; then
            return 1
        fi
    fi
    if command -v ping >/dev/null 2>&1; then
        timeout 2 ping -c 1 -W 1 1.1.1.1 >/dev/null 2>&1
        return $?
    fi
    return 0
}

STEAM_HAS_NETWORK=0
if has_network; then
    STEAM_HAS_NETWORK=1
fi

if [[ "${BATOCERA_STEAM_REQUIRE_NETWORK:-1}" == "1" ]] && [[ "${STEAM_HAS_NETWORK}" != "1" ]]; then
    echo "No internet connection detected; aborting Steam launch" >> "${log}"

    if [[ "${STEAM_FIRST_RUN_PENDING}" == "1" ]]; then
        mkdir -p "$(dirname "${STEAM_FIRST_RUN_PENDING_STAMP}")"
        : > "${STEAM_FIRST_RUN_PENDING_STAMP}"
        : > "${STEAM_FIRST_RUN_WIFI_STAMP}"
        echo "Steam first run is pending network; keeping ${STEAM_FIRST_RUN_WIFI_STAMP}" >> "${log}"
    fi

    if command -v batocera-flash-screen >/dev/null 2>&1; then
        if [[ "${STEAM_FIRST_RUN_PENDING}" == "1" ]]; then
            /usr/bin/batocera-flash-screen 6 "#ffffff" "No network connected." 22 >/dev/null 2>&1 || true
            /usr/bin/batocera-flash-screen 6 "#ffffff" "Please connect to Wi-Fi / internet and retry Steam." 18 >/dev/null 2>&1 || true
        else
            /usr/bin/batocera-flash-screen 6 "#ffffff" "No internet connection." 22 >/dev/null 2>&1 || true
            /usr/bin/batocera-flash-screen 6 "#ffffff" "Please connect to the internet and launch Steam again." 20 >/dev/null 2>&1 || true
        fi
    fi

    exit 1
fi

ensure_runtime_dir() {
    local uid
    local candidate

    runtime_dir_usable() {
        local runtime_candidate="$1"
        local runtime_uid="$2"

        [[ -n "${runtime_candidate}" ]] || return 1
        [[ "${runtime_candidate}" != "/run" && "${runtime_candidate}" != "/var/run" ]] || return 1
        [[ -d "${runtime_candidate}" && -w "${runtime_candidate}" ]] || return 1
        [[ "$(stat -c %u "${runtime_candidate}" 2>/dev/null || echo -1)" == "${runtime_uid}" ]] || return 1
    }

    uid="$(id -u)"

    if runtime_dir_usable "${XDG_RUNTIME_DIR:-}" "${uid}"; then
        return
    fi

    candidate="/run/user/${uid}"
    if mkdir -p "${candidate}" 2>/dev/null; then
        chmod 700 "${candidate}" 2>/dev/null || true
        if runtime_dir_usable "${candidate}" "${uid}"; then
            export XDG_RUNTIME_DIR="${candidate}"
            return
        fi
    fi

    candidate="/tmp/runtime-${uid}"
    mkdir -p "${candidate}"
    chmod 700 "${candidate}" 2>/dev/null || true
    export XDG_RUNTIME_DIR="${candidate}"
}
ensure_runtime_dir

ensure_audio_env() {
    local uid
    local pulse_socket=""

    uid="$(id -u)"

    if [[ -S /run/pulse/native ]]; then
        pulse_socket="/run/pulse/native"
    elif [[ -S "/run/user/${uid}/pulse/native" ]]; then
        pulse_socket="/run/user/${uid}/pulse/native"
    elif [[ -S "${XDG_RUNTIME_DIR}/pulse/native" ]]; then
        pulse_socket="${XDG_RUNTIME_DIR}/pulse/native"
    fi

    if [[ -n "${pulse_socket}" ]]; then
        export PULSE_SERVER="unix:${pulse_socket}"
        export SDL_AUDIODRIVER="pulseaudio"
        echo "Steam audio: using pulse socket ${pulse_socket}" >> "${log}"
    else
        echo "Steam audio: no pulse socket found; leaving default audio env" >> "${log}"
    fi

    if [[ -S /run/pipewire-0 ]]; then
        export PIPEWIRE_RUNTIME_DIR="/run"
        export PIPEWIRE_REMOTE="pipewire-0"
    fi
}
ensure_audio_env

if [[ "${BATOCERA_STEAM_GAMEPADUI:-1}" == "0" ]]; then
    export STEAM_GAMEPADUI=0
    export STEAM_FORCE_DESKTOPUI=1
else
    export STEAM_GAMEPADUI=1
    export STEAM_FORCE_DESKTOPUI=0
fi

setup_cef_remote_debugging() {
    local marker
    local -a candidates=(
        "/userdata/system/steam/.cef-enable-remote-debugging"
        "/userdata/system/.steam/steam/.cef-enable-remote-debugging"
        "/userdata/system/.local/share/Steam/.cef-enable-remote-debugging"
    )

    for marker in "${candidates[@]}"; do
        mkdir -p "$(dirname "${marker}")"
        touch "${marker}"
    done
}

start_decky_loader() {
    local decky_bin="${BATOCERA_STEAM_DECKY_BIN:-/userdata/system/homebrew/services/PluginLoader}"
    local decky_log="/userdata/system/logs/decky-loader.log"

    if [[ ! -x "${decky_bin}" ]]; then
        return
    fi

    if pgrep -x "$(basename "${decky_bin}")" >/dev/null 2>&1; then
        return
    fi

    setup_cef_remote_debugging
    echo "Starting Decky Loader from ${decky_bin}" >> "${log}"
    nohup "${decky_bin}" >> "${decky_log}" 2>&1 &
}

parse_resolution() {
    local value="${1:-}"
    if [[ "${value}" =~ ^[[:space:]]*([0-9]+)x([0-9]+)[[:space:]]*$ ]]; then
        printf '%s %s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
        return 0
    fi
    return 1
}

parse_positive_int() {
    local value="${1:-}"
    if [[ "${value}" =~ ^[0-9]+$ ]] && (( value > 0 )); then
        printf '%s\n' "${value}"
        return 0
    fi
    return 1
}

gamescope_help_cache=""

gamescope_supports_flag() {
    local flag="$1"
    if [[ -z "${gamescope_help_cache}" ]]; then
        gamescope_help_cache="$(gamescope --help 2>&1 || true)"
    fi
    [[ "${gamescope_help_cache}" == *"${flag}"* ]]
}

append_gamescope_flag() {
    local preferred="$1"
    local fallback="${2:-}"

    if gamescope_supports_flag "${preferred}"; then
        gs_args+=("${preferred}")
        return
    fi

    if [[ -n "${fallback}" ]] && gamescope_supports_flag "${fallback}"; then
        gs_args+=("${fallback}")
        return
    fi

    echo "Steam gamescope: skipping unsupported flag ${preferred}" >> "${log}"
}

append_gamescope_option() {
    local option="$1"
    local value="$2"

    if gamescope_supports_flag "${option}"; then
        gs_args+=("${option}" "${value}")
        return
    fi

    echo "Steam gamescope: skipping unsupported option ${option}" >> "${log}"
}

detect_output_resolution() {
    local parsed
    parsed="$(parse_resolution "${BATOCERA_STEAM_GS_OUTPUT_RES:-}" || true)"
    if [[ -n "${parsed}" ]]; then
        printf '%s\n' "${parsed}"
        return
    fi

    parsed="$(parse_resolution "${BATOCERA_STEAM_GS_DEFAULT_RES:-}" || true)"
    if [[ -n "${parsed}" ]]; then
        printf '%s\n' "${parsed}"
        return
    fi

    if command -v batocera-resolution >/dev/null 2>&1; then
        parsed="$(parse_resolution "$(batocera-resolution currentResolution 2>/dev/null || true)" || true)"
        if [[ -n "${parsed}" ]]; then
            printf '%s\n' "${parsed}"
            return
        fi
    fi

    printf '1280 720\n'
}

detect_nested_resolution() {
    local fallback_w="$1"
    local fallback_h="$2"
    local parsed

    parsed="$(parse_resolution "${BATOCERA_STEAM_GS_NESTED_RES:-}" || true)"
    if [[ -n "${parsed}" ]]; then
        printf '%s\n' "${parsed}"
        return
    fi

    printf '%s %s\n' "${fallback_w}" "${fallback_h}"
}

detect_refresh_rate() {
    local value

    value="$(parse_positive_int "${BATOCERA_STEAM_GS_NESTED_REFRESH:-}" || true)"
    if [[ -n "${value}" ]]; then
        printf '%s\n' "${value}"
        return
    fi

    if command -v batocera-resolution >/dev/null 2>&1; then
        value="$(batocera-resolution refreshRate 2>/dev/null || true)"
        if [[ "${value}" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
            awk -v rate="${value}" 'BEGIN { printf "%d\n", int(rate + 0.5) }'
            return
        fi
    fi

    printf '0\n'
}

if [[ "${STEAM_FIRST_RUN_PENDING}" == "1" ]] && [[ "${STEAM_HAS_NETWORK}" == "1" ]]; then
    rm -f "${STEAM_FIRST_RUN_WIFI_STAMP}"
fi

if [[ "${STEAM_FIRST_RUN_PENDING}" == "1" ]] && [[ "${STEAM_HAS_NETWORK}" == "1" ]] && command -v batocera-flash-screen >/dev/null 2>&1; then
    /usr/bin/batocera-flash-screen 6 "#ffffff" "Downloading Steam runtime components." 22 >/dev/null 2>&1 || true
    /usr/bin/batocera-flash-screen "${BATOCERA_STEAM_FIRST_RUN_WAIT_SECS:-18}" "#ffffff" "This will take a while. Please wait..." 20 >/dev/null 2>&1 || true
fi

finalize_first_run_state() {
    local session_rc="$1"

    if [[ "${STEAM_FIRST_RUN_PENDING}" != "1" ]] || [[ "${STEAM_HAS_NETWORK}" != "1" ]]; then
        return
    fi

    if [[ "${session_rc}" == "0" ]]; then
        rm -f "${STEAM_FIRST_RUN_PENDING_STAMP}" "${STEAM_FIRST_RUN_WIFI_STAMP}"
        echo "Steam first run completed; cleared pending first-run stamp" >> "${log}"
        return
    fi

    : > "${STEAM_FIRST_RUN_PENDING_STAMP}"
    echo "Steam first run ended with status ${session_rc}; keeping pending first-run stamp" >> "${log}"
}

run_ally_hotkey_hook gameStart || true
recover_hotkeys
reassert_ally_steam_hotkeys_later

ensure_system_bus_address() {
    # Steam queries org.freedesktop.DisplayManager on the system bus.
    # Prefer the real system bus socket so Steam and our stub are on the same bus.
    if [[ -n "${DBUS_SYSTEM_BUS_ADDRESS:-}" ]]; then
        return
    fi

    if [[ -S /run/dbus/system_bus_socket ]]; then
        export DBUS_SYSTEM_BUS_ADDRESS="unix:path=/run/dbus/system_bus_socket"
        return
    fi

    # Last resort for atypical environments.
    if [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
        export DBUS_SYSTEM_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS}"
    fi
}

start_displaymanager_stub() {
    local stub="/usr/bin/batocera-displaymanager-stub"
    local stub_pattern='(^|/)batocera-displaymanager-stub([[:space:]]|$)'
    local started=0

    probe_displaymanager_stub() {
        if ! command -v dbus-send >/dev/null 2>&1; then
            return 1
        fi

        timeout 2 dbus-send --system --print-reply \
            --dest=org.freedesktop.DisplayManager \
            /org/freedesktop/DisplayManager \
            org.freedesktop.DisplayManager.GetSeats >/dev/null 2>&1
    }

    if [[ ! -x "${stub}" ]]; then
        return
    fi

    if ! pgrep -f "${stub_pattern}" >/dev/null 2>&1; then
        nohup "${stub}" >> "${log}" 2>&1 &
        started=1
        sleep 0.2
    fi

    if probe_displaymanager_stub; then
        return
    fi

    echo "DisplayManager stub probe failed, retrying once" >> "${log}"
    pkill -f "${stub_pattern}" >/dev/null 2>&1 || true
    nohup "${stub}" >> "${log}" 2>&1 &
    sleep 0.2
    if ! probe_displaymanager_stub; then
        echo "DisplayManager stub still unavailable after retry" >> "${log}"
        return
    fi

    if [[ "${started}" -eq 1 ]]; then
        echo "DisplayManager stub started and probed successfully" >> "${log}"
    fi
}

start_uimode_watch() {
    local watcher="/usr/bin/batocera-steam-uimode-watch"
    local watcher_pattern='(^|/)batocera-steam-uimode-watch([[:space:]]|$)'

    if [[ "${BATOCERA_STEAM_UI_WATCH_ENABLE:-1}" == "0" ]]; then
        return
    fi

    if [[ ! -x "${watcher}" ]]; then
        echo "Steam UI mode watcher missing or not executable: ${watcher}" >> "${log}"
        return
    fi

    pkill -f "${watcher_pattern}" >/dev/null 2>&1 || true
    nohup "${watcher}" >> "${log}" 2>&1 &
    echo "Steam UI mode watcher started" >> "${log}"
}

