start_decky_loader
ensure_system_bus_address
start_networkmanager_stub
start_login1_stub
start_consolekit_stub
start_displaymanager_stub
start_uimode_watch

if command -v gamescope >/dev/null 2>&1 && [[ "${BATOCERA_STEAM_USE_GAMESCOPE:-1}" != "0" ]]; then
    read -r out_w out_h <<< "$(detect_output_resolution)"
    read -r nest_w nest_h <<< "$(detect_nested_resolution "${out_w}" "${out_h}")"
    refresh_rate="$(detect_refresh_rate)"

    gs_args=(--steam --rt -f --expose-wayland -W "${out_w}" -H "${out_h}" -w "${nest_w}" -h "${nest_h}")

    case "${BATOCERA_STEAM_GS_BACKEND:-}" in
        auto|drm|wayland|sdl|headless)
            append_gamescope_option "--backend" "${BATOCERA_STEAM_GS_BACKEND}"
            ;;
    esac

    if xwayland_count="$(parse_positive_int "${BATOCERA_STEAM_GS_XWAYLAND_COUNT:-}" || true)"; [[ -n "${xwayland_count}" ]]; then
        append_gamescope_option "--xwayland-count" "${xwayland_count}"
    fi

    if [[ -n "${BATOCERA_STEAM_GS_PREFER_VK_DEVICE:-}" ]]; then
        append_gamescope_option "--prefer-vk-device" "${BATOCERA_STEAM_GS_PREFER_VK_DEVICE}"
    fi

    if [[ "${BATOCERA_STEAM_GS_DISABLE_DAMAGE_TRACKING:-0}" != "0" ]]; then
        append_gamescope_flag "--disable-damage-tracking"
    fi

    if [[ "${BATOCERA_STEAM_GS_DISABLE_HW_COMPOSITION:-0}" != "0" ]]; then
        append_gamescope_flag "--disable-hw-composition" "--disable-layers"
    fi

    if [[ "${BATOCERA_STEAM_GS_ADAPTIVE_SYNC:-0}" != "0" ]]; then
        append_gamescope_flag "--adaptive-sync"
    fi

    if [[ "${BATOCERA_STEAM_GS_FORCE_COMPOSITION_PIPELINE:-0}" != "0" ]]; then
        append_gamescope_flag "--force-composition-pipeline" "--force-composition"
    fi

    if [[ "${BATOCERA_STEAM_GS_MANGOAPP:-0}" != "0" ]]; then
        append_gamescope_flag "--mangoapp"
    fi

    if [[ "${BATOCERA_STEAM_GS_FORCE_WINDOWS_FULLSCREEN:-0}" != "0" ]]; then
        append_gamescope_flag "--force-windows-fullscreen"
    fi

    if [[ "${refresh_rate}" =~ ^[0-9]+$ ]] && (( refresh_rate > 0 )); then
        gs_args+=(-r "${refresh_rate}")
    fi

    if nested_unfocused_refresh="$(parse_positive_int "${BATOCERA_STEAM_GS_NESTED_UNFOCUSED_REFRESH:-}" || true)"; [[ -n "${nested_unfocused_refresh}" ]]; then
        append_gamescope_option "--nested-unfocused-refresh" "${nested_unfocused_refresh}"
    fi

    if framerate_limit="$(parse_positive_int "${BATOCERA_STEAM_GS_FRAMERATE_LIMIT:-}" || true)"; [[ -n "${framerate_limit}" ]]; then
        gs_args+=(--framerate-limit "${framerate_limit}")
    fi

    if [[ -n "${BATOCERA_STEAM_GS_SCALER:-}" ]]; then
        gs_args+=(-S "${BATOCERA_STEAM_GS_SCALER}")
    fi
    if [[ -n "${BATOCERA_STEAM_GS_FILTER:-}" ]]; then
        gs_args+=(-F "${BATOCERA_STEAM_GS_FILTER}")
    fi
    if [[ -n "${BATOCERA_STEAM_GS_SHARPNESS:-}" ]]; then
        gs_args+=(--sharpness "${BATOCERA_STEAM_GS_SHARPNESS}")
    fi
    if [[ "${BATOCERA_STEAM_GS_HDR:-0}" == "1" ]]; then
        gs_args+=(--hdr-enabled)
    fi

    if [[ -n "${BATOCERA_STEAM_GS_STATS_PATH:-}" ]]; then
        append_gamescope_option "--stats-path" "${BATOCERA_STEAM_GS_STATS_PATH}"
    fi

    if [[ "${BATOCERA_STEAM_GS_DISABLE_COLOR_MANAGEMENT:-0}" != "0" ]]; then
        append_gamescope_flag "--disable-color-management"
    fi

    if [[ "${BATOCERA_STEAM_GS_DISABLE_XRES:-0}" != "0" ]]; then
        append_gamescope_flag "--disable-xres"
    fi

    if [[ "${BATOCERA_STEAM_GS_IMMEDIATE_FLIPS:-0}" != "0" ]]; then
        append_gamescope_flag "--immediate-flips"
    fi

    echo "Steam gamescope args: ${gs_args[*]}" >> "${log}"
    set +e
    gamescope "${gs_args[@]}" -- "$@"
    session_rc=$?
    set -e
    finalize_first_run_state "${session_rc}"
    exit "${session_rc}"
fi

echo "Steam session: gamescope unavailable or disabled, launching without it" >> "${log}"
set +e
"$@"
session_rc=$?
set -e
finalize_first_run_state "${session_rc}"
exit "${session_rc}"
