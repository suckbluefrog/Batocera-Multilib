config BR2_PACKAGE_LUTRIS
	bool "lutris"
	depends on BR2_x86_64
	# Baseline runtime coverage for native Linux Lutris titles.
	select BR2_PACKAGE_BATOCERA_STEAM_REQUIREMENTS
	select BR2_PACKAGE_SDL2_IMAGE
	select BR2_PACKAGE_SDL2_MIXER
	select BR2_PACKAGE_SDL2_TTF
	select BR2_PACKAGE_PULSEAUDIO
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_OPENSSL_FORCE_LIBOPENSSL
	select BR2_PACKAGE_WEBP
	select BR2_PACKAGE_WEBP_DEMUX
	select BR2_PACKAGE_WEBP_MUX
	select BR2_PACKAGE_FAUDIO
	select BR2_PACKAGE_UTIL_LINUX_LIBUUID
	select BR2_PACKAGE_IRRLICHT			if BR2_PACKAGE_XORG7 && BR2_PACKAGE_HAS_LIBGL
	select BR2_PACKAGE_XAPP_XRANDR			if BR2_PACKAGE_XORG7
	select BR2_PACKAGE_MESA3D_DEMOS			if BR2_PACKAGE_XORG7 && BR2_PACKAGE_HAS_LIBGL
	# Native Lutris client stack.
	select BR2_PACKAGE_PYTHON3
	select BR2_PACKAGE_PYTHON_SETUPTOOLS
	select BR2_PACKAGE_PYTHON_PYCAIRO
	select BR2_PACKAGE_PYTHON_GOBJECT
	select BR2_PACKAGE_PYTHON_REQUESTS
	select BR2_PACKAGE_PYTHON_PILLOW
	select BR2_PACKAGE_PYTHON_PYYAML
	select BR2_PACKAGE_PYTHON_SETPROCTITLE
	select BR2_PACKAGE_PYTHON_DISTRO
	select BR2_PACKAGE_PYTHON_EVDEV
	select BR2_PACKAGE_PYTHON_LXML
	select BR2_PACKAGE_PYTHON_PROTOBUF
	select BR2_PACKAGE_DBUS
	select BR2_PACKAGE_DBUS_PYTHON
	select BR2_PACKAGE_LIBGTK3
	select BR2_PACKAGE_FONT_AWESOME
	select BR2_PACKAGE_WEBKITGTK
	help
	  Lutris built natively from source.

comment "lutris needs an x86_64 target"
	depends on !BR2_x86_64
