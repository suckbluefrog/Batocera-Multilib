From d7d913db44c3a9e89834f669618d2f47e4d8d544 Mon Sep 17 00:00:00 2001
From: Batocera Builder <noreply@batocera.org>
Date: Sun, 15 Feb 2026 10:10:00 +0000
Subject: [PATCH] emu: use vmrs/vmsr instead of arm fpscr builtins

GCC 13 in some armhf Buildroot configs does not expose
__builtin_arm_get_fpscr/__builtin_arm_set_fpscr, even when ARM FP
macros are defined. Use inline assembly for FPSCR access instead.
---
 src/emu/x86emu.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/src/emu/x86emu.c b/src/emu/x86emu.c
index 2a80479..1752a00 100644
--- a/src/emu/x86emu.c
+++ b/src/emu/x86emu.c
@@ -538,6 +538,7 @@ void applyFlushTo0(x86emu_t* emu)
 #elif defined(__arm__) && (defined(__VFP_FP__) || defined(__ARM_FP)) && !defined(__SOFTFP__)
-    uint64_t fpscr = __builtin_arm_get_fpscr();
-    fpscr &= ~(1<<24);                     // clear bit FZ (24)
-    fpscr |= (emu->mxcsr.f.MXCSR_FZ)<<24;  // set FZ as mxcsr FZ
-    __builtin_arm_set_fpscr(fpscr);
+    uint32_t fpscr;
+    __asm__ __volatile__("vmrs %0, fpscr" : "=r"(fpscr));
+    fpscr &= ~(1u << 24);                           // clear bit FZ (24)
+    fpscr |= ((uint32_t)emu->mxcsr.f.MXCSR_FZ) << 24; // set FZ as mxcsr FZ
+    __asm__ __volatile__("vmsr fpscr, %0" : : "r"(fpscr));
 #elif defined(__arm__)

