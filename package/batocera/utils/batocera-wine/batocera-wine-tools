            2 "Download Wine-TKG-Staging builds" \
            3 "Download Wine-GE Custom builds" \
            4 "Download GE-Proton builds" \
            5 "Prepare VC++ / DX9 / Steamy installers for next run" \
            6 "Easy Batocera Winetricks" \
            7 "Easy autorun.cmd creator" \
            8 "Convert .pc folder to .wine folder" \
            9 "Compress .wine folder to .wsquashfs or .wtgz" \
            10 "Decompress .wsquashfs / .wtgz back to .wine" \
            99 "Exit" \
            2>&1 >/dev/tty) || {
