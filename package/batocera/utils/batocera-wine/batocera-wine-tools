#!/bin/bash
set -u -o pipefail

ROOT_ROMS_WINDOWS="/userdata/roms/windows"
ROOT_WINE_BOTTLES="/userdata/system/wine-bottles/windows"
ROOT_WINE_CUSTOM="/userdata/system/wine/custom"
ROOT_WINE_EXE="/userdata/system/wine/exe"
ROOT_WINE_EXE_BAK="/userdata/system/wine/exe.bak"
WINETRICKS_ALL_URL="https://raw.githubusercontent.com/Winetricks/winetricks/master/files/verbs/all.txt"
KRON4EK_RELEASES_URL="https://api.github.com/repos/Kron4ek/Wine-Builds/releases?per_page=300"
WINE_GE_RELEASES_URL="https://api.github.com/repos/GloriousEggroll/wine-ge-custom/releases?per_page=100"
PROTON_GE_RELEASES_URL="https://api.github.com/repos/GloriousEggroll/proton-ge-custom/releases?per_page=100"

clear_screen() {
    clear >/dev/null 2>&1 || true
}

msg_box() {
    dialog --msgbox "$1" 14 78 2>&1 >/dev/tty
    clear_screen
}

yes_no() {
    dialog --yesno "$1" 14 78 2>&1 >/dev/tty
    local rc=$?
    clear_screen
    return "$rc"
}

info_box() {
    dialog --infobox "$1" 6 72 2>&1 >/dev/tty
}

dialog_capture_stdout() {
    dialog --stdout "$@" </dev/tty 2>/dev/tty
}

require_dialog() {
    if ! command -v dialog >/dev/null 2>&1; then
        echo "batocera-wine-tools requires dialog." >&2
        exit 1
    fi
    if ! [ -t 0 ] && ! [ -t 1 ] && ! [ -t 2 ]; then
        echo "batocera-wine-tools requires an interactive terminal." >&2
        exit 1
    fi
}

require_commands() {
    local missing=() cmd
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
    done
    if [ "${#missing[@]}" -gt 0 ]; then
        msg_box "Missing required commands: ${missing[*]}"
        return 1
    fi
    return 0
}

select_single() {
    local title="$1"
    local prompt="$2"
    shift 2
    local entries=("$@")
    local options=()
    local idx choice

    [ "${#entries[@]}" -gt 0 ] || return 1

    for idx in "${!entries[@]}"; do
        options+=("$((idx + 1))" "${entries[$idx]}")
    done

    choice=$(dialog --clear --title "$title" --menu "$prompt" 22 100 12 "${options[@]}" 2>&1 >/dev/tty) || {
        clear_screen
        return 1
    }
    clear_screen
    printf '%s\n' "${entries[$((choice - 1))]}"
}

select_multiple_from_json() {
    local title="$1"
    local prompt="$2"
    local json="$3"
    local options=()
    local count idx label

    count=$(printf '%s' "$json" | jq 'length') || return 1
    [ "$count" -gt 0 ] || return 1

    for ((idx=0; idx<count; idx++)); do
        label=$(printf '%s' "$json" | jq -r ".[$idx].label")
        options+=("$((idx + 1))" "$label" off)
    done

    dialog --separate-output --title "$title" --checklist "$prompt" 24 100 14 "${options[@]}" 2>&1 >/dev/tty
    local rc=$?
    clear_screen
    return "$rc"
}

select_radiolist() {
    local title="$1"
    local prompt="$2"
    shift 2
    dialog_capture_stdout --title "$title" --radiolist "$prompt" 20 90 12 "$@"
    local rc=$?
    clear_screen
    return "$rc"
}

fetch_json() {
    curl -fsSL "$1"
}

download_with_gauge() {
    local url="$1"
    local output="$2"
    local title="$3"
    local status_file
    status_file=$(mktemp)

    mkdir -p "$(dirname "$output")" || return 1
    rm -f "$output"

    (
        if wget --tries=10 --no-check-certificate --no-cache --no-cookies --progress=dot --timeout=60 -O "$output" "$url" 2>&1 | \
            while IFS= read -r line; do
                if [[ "$line" =~ ([0-9]{1,3})% ]]; then
                    echo "${BASH_REMATCH[1]}"
                fi
            done; then
            echo 0 > "$status_file"
        else
            echo 1 > "$status_file"
        fi
        echo 100
    ) | dialog --gauge "\n${title}" 9 75 0 2>&1 >/dev/tty

    local rc=1
    [ -f "$status_file" ] && rc=$(cat "$status_file")
    rm -f "$status_file"
    clear_screen
    [ "$rc" -eq 0 ] && [ -s "$output" ]
}

archive_entry_count() {
    local archive="$1"
    case "$archive" in
        *.tar.gz) tar -tf "$archive" | wc -l ;;
        *.tar.xz) tar -tJf "$archive" | wc -l ;;
        *) return 1 ;;
    esac
}

archive_top_count() {
    local archive="$1"
    case "$archive" in
        *.tar.gz) tar -tf "$archive" | awk -F/ 'NF {print $1}' | sort -u | wc -l ;;
        *.tar.xz) tar -tJf "$archive" | awk -F/ 'NF {print $1}' | sort -u | wc -l ;;
        *) return 1 ;;
    esac
}

extract_archive_with_gauge() {
    local archive="$1"
    local destination="$2"
    local title="$3"
    local total top fifo status_file count percent
    total=$(archive_entry_count "$archive") || return 1
    [ "$total" -gt 0 ] || return 1
    top=$(archive_top_count "$archive") || return 1

    mkdir -p "$destination" || return 1

    fifo=$(mktemp -u)
    status_file=$(mktemp)
    rm -f "$fifo"
    mkfifo "$fifo" || return 1

    count=0
    (
        case "$archive" in
            *.tar.gz)
                if [ "$top" -eq 1 ]; then
                    tar --strip-components=1 -xzf "$archive" -C "$destination" --checkpoint=10 --checkpoint-action=echo='%u' > "$fifo" 2>/dev/null &
                else
                    tar -xzf "$archive" -C "$destination" --checkpoint=10 --checkpoint-action=echo='%u' > "$fifo" 2>/dev/null &
                fi
                ;;
            *.tar.xz)
                if [ "$top" -eq 1 ]; then
                    tar --strip-components=1 -xJf "$archive" -C "$destination" --checkpoint=10 --checkpoint-action=echo='%u' > "$fifo" 2>/dev/null &
                else
                    tar -xJf "$archive" -C "$destination" --checkpoint=10 --checkpoint-action=echo='%u' > "$fifo" 2>/dev/null &
                fi
                ;;
            *)
                echo 1 > "$status_file"
                echo 100
                exit 0
                ;;
        esac
        local tar_pid=$!
        while IFS= read -r _; do
            count=$((count + 10))
            percent=$((count * 100 / total))
            [ "$percent" -gt 100 ] && percent=100
            echo "$percent"
        done < "$fifo"
        if wait "$tar_pid"; then
            echo 0 > "$status_file"
        else
            echo 1 > "$status_file"
        fi
        echo 100
    ) | dialog --gauge "\n${title}" 9 75 0 2>&1 >/dev/tty

    local rc=1
    [ -f "$status_file" ] && rc=$(cat "$status_file")
    rm -f "$status_file" "$fifo"
    clear_screen
    [ "$rc" -eq 0 ]
}

postprocess_proton_dir() {
    local destination="$1"
    if [ -d "$destination/files" ]; then
        shopt -s dotglob nullglob
        mv "$destination/files"/* "$destination/" 2>/dev/null || true
        shopt -u dotglob nullglob
        rmdir "$destination/files" 2>/dev/null || true
    fi
}

archive_dir_name() {
    local archive="$1"
    case "$archive" in
        *.tar.gz) printf '%s\n' "${archive%.tar.gz}" ;;
        *.tar.xz) printf '%s\n' "${archive%.tar.xz}" ;;
        *) return 1 ;;
    esac
}

download_release_selection() {
    local title="$1"
    local prompt="$2"
    local json="$3"
    local selections idx archive url outdir tmpfile dirname

    mkdir -p "$ROOT_WINE_CUSTOM" || return 1
    selections=$(select_multiple_from_json "$title" "$prompt" "$json") || return 1
    [ -n "$selections" ] || return 1

    for idx in $selections; do
        idx=$((idx - 1))
        archive=$(printf '%s' "$json" | jq -r ".[$idx].archive")
        url=$(printf '%s' "$json" | jq -r ".[$idx].url")
        dirname=$(archive_dir_name "$archive") || {
            msg_box "Unsupported archive format: ${archive}"
            continue
        }
        outdir="${ROOT_WINE_CUSTOM}/${dirname}"
        tmpfile="${ROOT_WINE_CUSTOM}/${archive}"

        if ! download_with_gauge "$url" "$tmpfile" "Downloading ${archive}..."; then
            msg_box "Download failed: ${archive}"
            rm -f "$tmpfile"
            continue
        fi

        mkdir -p "$outdir" || return 1
        if ! extract_archive_with_gauge "$tmpfile" "$outdir" "Extracting ${archive}..."; then
            msg_box "Extraction failed: ${archive}"
            rm -f "$tmpfile"
            continue
        fi
        rm -f "$tmpfile"

        case "$archive" in
            GE-Proton*.tar.gz|Proton*.tar.gz|proton-*.tar.gz)
                postprocess_proton_dir "$outdir"
                ;;
        esac
    done

    msg_box "Selected downloads completed."
}

