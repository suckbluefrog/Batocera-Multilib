    msg_box "Dependency installers prepared in ${ROOT_WINE_EXE}.\n\nAny previous set was moved to ${ROOT_WINE_EXE_BAK} if it existed."
}

collect_prefixes() {
    local results=()
    local path

    if [ -d "$ROOT_ROMS_WINDOWS" ]; then
        while IFS= read -r -d '' path; do
            results+=("$path")
        done < <(find "$ROOT_ROMS_WINDOWS" -maxdepth 1 -mindepth 1 -type d \( -name '*.pc' -o -name '*.wine' \) -print0 2>/dev/null)
    fi

    if [ -d "$ROOT_WINE_BOTTLES" ]; then
        while IFS= read -r -d '' path; do
            results+=("$path")
        done < <(find "$ROOT_WINE_BOTTLES" -type d -name '*.wine' -print0 2>/dev/null)
    fi

    printf '%s\n' "${results[@]}"
}

select_prefix() {
    local prefixes=()
    while IFS= read -r line; do
        [ -n "$line" ] && prefixes+=("$line")
    done < <(collect_prefixes)

    if [ "${#prefixes[@]}" -eq 0 ]; then
        msg_box "No Wineprefix directories found."
        return 1
    fi

    select_single "Select Wineprefix" "Choose a Wineprefix:" "${prefixes[@]}"
}

create_autorun_cmd_menu() {
    local prefix file exe_dir exe_file files=() rel_files=()
    prefix=$(select_prefix) || return 1

    while IFS= read -r -d '' file; do
        files+=("$file")
        rel_files+=("$(realpath --relative-to="$prefix" "$file")")
    done < <(find "$prefix" -type f \( -iname '*.exe' -o -iname '*.bat' -o -iname '*.com' \) -print0 2>/dev/null)

    if [ "${#rel_files[@]}" -eq 0 ]; then
        msg_box "No executable files found in ${prefix}."
        return 1
    fi

    file=$(select_single "Select Executable" "Choose the executable to run:" "${rel_files[@]}") || return 1
    exe_dir=$(dirname "$file")
    exe_file=$(basename "$file")

    {
        [ "$exe_dir" != "." ] && printf 'DIR=%s\n' "$exe_dir"
        printf 'CMD="%s"\n' "$exe_file"
    } > "$prefix/autorun.cmd"

    msg_box "autorun.cmd created in:\n${prefix}"
}

run_easy_winetricks() {
    require_commands curl jq batocera-wine || return 1
    local prefix common pkg temp_file parsed options=() line tag desc

    while true; do
        prefix=$(select_prefix) || return 1

        while true; do
            pkg=""
            if yes_no "Do you want to install a common VC++ runtime or DirectX9 component?"; then
                common=$(select_radiolist "Common Dependencies" "Select one dependency to install:" \
                    vcrun2008 "Visual C++ 2008" off \
                    vcrun2010 "Visual C++ 2010" off \
                    vcrun2012 "Visual C++ 2012" off \
                    vcrun2013 "Visual C++ 2013" off \
                    vcrun2022 "Visual C++ 2015-2022" off \
                    d3dx9_43 "DirectX9 (d3dx9_43)" off) || true
                pkg="$common"
            elif yes_no "Do you want to install another Winetricks package from the official list?"; then
                temp_file=$(mktemp)
                parsed=$(mktemp)
                if curl -fsSL "$WINETRICKS_ALL_URL" -o "$temp_file"; then
                    grep -v '^=====' "$temp_file" | grep -v '^[[:space:]]*$' > "$parsed"
                    while IFS= read -r line; do
                        tag=$(awk '{print $1}' <<<"$line")
                        desc=$(cut -d' ' -f2- <<<"$line")
                        options+=("$tag" "$desc" off)
                    done < "$parsed"
                    pkg=$(dialog_capture_stdout --title "Winetricks Packages" --radiolist "Select one additional Winetricks package:" 30 100 14 "${options[@]}") || true
                    clear_screen
                else
                    msg_box "Failed to fetch the Winetricks package list."
                fi
                rm -f "$temp_file" "$parsed"
                options=()
            fi

            [ -n "$pkg" ] || break

            msg_box "Check the main display for any installer prompts.\n\nApplying ${pkg} to:\n${prefix}"
            export DISPLAY=:0.0
            command -v unclutter-remote >/dev/null 2>&1 && unclutter-remote -s || true
            batocera-wine windows tricks "$prefix" "$pkg" unattended
            command -v unclutter-remote >/dev/null 2>&1 && unclutter-remote -h || true
            msg_box "Winetricks processing complete."

            yes_no "Apply another trick to the same prefix?" || break
        done

        yes_no "Do you want to process another Wineprefix?" || break
    done
}

choose_compression_method() {
    select_radiolist "Compression Type" "Choose compression method:" \
        wsquashfs "SquashFS - best for larger games with small writes" off \
        wtgz "WTGZ - best for smaller games with larger writes" on
}

compress_wine_folder() {
    require_commands batocera-wine || return 1
    local folders=() path selected method output

    if [ -d "$ROOT_ROMS_WINDOWS" ]; then
        while IFS= read -r -d '' path; do
            folders+=("$path")
        done < <(find "$ROOT_ROMS_WINDOWS" -maxdepth 1 -mindepth 1 -type d -name '*.wine' -print0 2>/dev/null)
    fi

    if [ "${#folders[@]}" -eq 0 ]; then
        msg_box "No .wine folders found in ${ROOT_ROMS_WINDOWS}."
        return 1
    fi

    selected=$(select_single "Select .wine Folder" "Choose a .wine folder to compress:" "${folders[@]}") || return 1
    method=$(choose_compression_method) || return 1

    info_box "Compressing $(basename "$selected")..."
    case "$method" in
        wsquashfs)
            batocera-wine windows wine2squashfs "$selected"
            output="${selected%.wine}.wsquashfs"
            ;;
        wtgz)
            batocera-wine windows wine2winetgz "$selected"
            output="${selected%.wine}.wtgz"
            ;;
        *)
            clear_screen
            return 1
            ;;
    esac
    clear_screen

    if [ -f "$output" ]; then
        msg_box "Compression complete.\nOutput: ${output}"
        if yes_no "Delete the source .wine folder?\n\n${selected}"; then
            rm -rf "$selected"
            msg_box "Deleted ${selected}."
        fi
    else
        msg_box "Compression failed. Expected output not found:\n${output}"
    fi
}

decompress_wine_archive() {
    require_commands tar unsquashfs || return 1
    local files=() path selected output_dir

    if [ -d "$ROOT_ROMS_WINDOWS" ]; then
        while IFS= read -r -d '' path; do
            files+=("$path")
        done < <(find "$ROOT_ROMS_WINDOWS" -maxdepth 1 -mindepth 1 -type f \( -name '*.wsquashfs' -o -name '*.wtgz' -o -name '*.tgz' \) -print0 2>/dev/null)
    fi

    if [ "${#files[@]}" -eq 0 ]; then
        msg_box "No .wsquashfs, .wtgz, or .tgz files found in ${ROOT_ROMS_WINDOWS}."
        return 1
    fi

    selected=$(select_single "Select Archive" "Choose a compressed Windows image to extract:" "${files[@]}") || return 1
    case "$selected" in
        *.wsquashfs) output_dir="${selected%.wsquashfs}.wine" ;;
        *.wtgz) output_dir="${selected%.wtgz}.wine" ;;
        *.tgz) output_dir="${selected%.tgz}.wine" ;;
        *) return 1 ;;
    esac

    if [ -e "$output_dir" ]; then
        yes_no "${output_dir} already exists. Replace it?" || return 1
        rm -rf "$output_dir"
    fi
    mkdir -p "$output_dir" || return 1

    info_box "Extracting $(basename "$selected")..."
    case "$selected" in
        *.wsquashfs)
            unsquashfs -d "$output_dir" "$selected" >/dev/null
            ;;
        *.wtgz|*.tgz)
            tar -xzf "$selected" -C "$output_dir"
            ;;
    esac
    clear_screen

    msg_box "Extraction complete.\nOutput: ${output_dir}"
    if yes_no "Delete the compressed archive?\n\n${selected}"; then
        rm -f "$selected"
        msg_box "Deleted ${selected}."
    fi
}

convert_pc_to_wine() {
    local pc_folders=() bottle_folders=() selected_pc selected_bottle new_path method output path

    if [ -d "$ROOT_ROMS_WINDOWS" ]; then
        while IFS= read -r -d '' path; do
            pc_folders+=("$path")
        done < <(find "$ROOT_ROMS_WINDOWS" -maxdepth 1 -mindepth 1 -type d -name '*.pc' -print0 2>/dev/null)
    fi
    if [ "${#pc_folders[@]}" -eq 0 ]; then
        msg_box "No .pc folders found in ${ROOT_ROMS_WINDOWS}."
        return 1
    fi

    if [ -d "$ROOT_WINE_BOTTLES" ]; then
        while IFS= read -r -d '' path; do
            bottle_folders+=("$path")
        done < <(find "$ROOT_WINE_BOTTLES" -type d -name '*.wine' -print0 2>/dev/null)
    fi
    if [ "${#bottle_folders[@]}" -eq 0 ]; then
        msg_box "No .wine folders found in ${ROOT_WINE_BOTTLES}."
        return 1
    fi

    msg_box "You must run the Windows game in a .pc folder at least once before Batocera generates a matching wine bottle."

    selected_pc=$(select_single "Select .pc Folder" "Choose the .pc folder to convert:" "${pc_folders[@]}") || return 1
    selected_bottle=$(select_single "Select Wine Bottle" "Choose the matching wine bottle:" "${bottle_folders[@]}") || return 1

    yes_no "Copy data from:\n${selected_bottle}\n\ninto:\n${selected_pc}\n\nthen delete the original bottle and rename the game folder to .wine?" || return 1

    cp -a "$selected_bottle"/. "$selected_pc"/ || {
        msg_box "Failed to copy bottle contents."
        return 1
    }
    rm -rf "$selected_bottle" || {
        msg_box "Failed to remove source bottle ${selected_bottle}."
        return 1
    }

    new_path="${selected_pc%.pc}.wine"
    mv "$selected_pc" "$new_path" || {
        msg_box "Failed to rename ${selected_pc} to ${new_path}."
        return 1
    }

    msg_box "Conversion complete.\nNew folder: ${new_path}"

    if yes_no "Compress the new .wine folder now?"; then
        method=$(choose_compression_method) || return 0
        info_box "Compressing $(basename "$new_path")..."
        case "$method" in
            wsquashfs)
                batocera-wine windows wine2squashfs "$new_path"
                output="${new_path%.wine}.wsquashfs"
                ;;
            wtgz)
                batocera-wine windows wine2winetgz "$new_path"
                output="${new_path%.wine}.wtgz"
                ;;
        esac
        clear_screen
        msg_box "Compression complete.\nOutput: ${output}"
        if yes_no "Delete the .wine folder after compression?\n\n${new_path}"; then
            rm -rf "$new_path"
            msg_box "Deleted ${new_path}."
        fi
    fi
}

