            vcredist_1519_x86) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x86_2015_2019.exe" "$ROOT_WINE_EXE/vcredist_x86_2015_2019.exe" "Downloading VC++ 2015-2019 (x86)..." ;;
            vcredist_1519_x64) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x64_2015_2019.exe" "$ROOT_WINE_EXE/vcredist_x64_2015_2019.exe" "Downloading VC++ 2015-2019 (x64)..." ;;
            vcredist_2019_x86) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x86_2019.exe" "$ROOT_WINE_EXE/vcredist_x86_2019.exe" "Downloading VC++ 2019 (x86)..." ;;
            vcredist_2019_x64) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x64_2019.exe" "$ROOT_WINE_EXE/vcredist_x64_2019.exe" "Downloading VC++ 2019 (x64)..." ;;
            vcredist_2017_x86) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x86_2017.exe" "$ROOT_WINE_EXE/vcredist_x86_2017.exe" "Downloading VC++ 2017 (x86)..." ;;
            vcredist_2017_x64) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x64_2017.exe" "$ROOT_WINE_EXE/vcredist_x64_2017.exe" "Downloading VC++ 2017 (x64)..." ;;
            vcredist_2015_x86) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x86_2015.exe" "$ROOT_WINE_EXE/vcredist_x86_2015.exe" "Downloading VC++ 2015 (x86)..." ;;
            vcredist_2015_x64) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x64_2015.exe" "$ROOT_WINE_EXE/vcredist_x64_2015.exe" "Downloading VC++ 2015 (x64)..." ;;
            vcredist_2013_x86) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x86_2013.exe" "$ROOT_WINE_EXE/vcredist_x86_2013.exe" "Downloading VC++ 2013 (x86)..." ;;
            vcredist_2013_x64) download_with_gauge "https://batocera.org/users/liberodark/wine/vcredist_x64_2013.exe" "$ROOT_WINE_EXE/vcredist_x64_2013.exe" "Downloading VC++ 2013 (x64)..." ;;
