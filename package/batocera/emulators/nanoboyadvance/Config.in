config BR2_PACKAGE_NANOBOYADVANCE
    bool "nanoboyadvance"
    depends on BR2_INSTALL_LIBSTDCPP
    depends on BR2_PACKAGE_XORG7
    depends on BR2_PACKAGE_HAS_LIBGL
    select BR2_PACKAGE_BATOCERA_SDL2
    select BR2_PACKAGE_LIBGLEW
    select BR2_PACKAGE_LIBGLU
    help
      NanoBoyAdvance is a cycle-accurate Game Boy Advance emulator.

      https://github.com/nba-emu/NanoBoyAdvance

comment "nanoboyadvance needs X.org, OpenGL, and a toolchain w/ C++"
    depends on !BR2_INSTALL_LIBSTDCPP || !BR2_PACKAGE_XORG7 || !BR2_PACKAGE_HAS_LIBGL
