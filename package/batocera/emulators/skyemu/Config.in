config BR2_PACKAGE_SKYEMU
    bool "skyemu"
    depends on BR2_INSTALL_LIBSTDCPP
    depends on BR2_PACKAGE_XORG7
    depends on BR2_PACKAGE_HAS_LIBGL
    select BR2_PACKAGE_BATOCERA_SDL2
    select BR2_PACKAGE_LIBCURL_CURL
    select BR2_PACKAGE_OPENSSL
    select BR2_PACKAGE_ALSA_LIB
    select BR2_PACKAGE_XLIB_LIBX11
    select BR2_PACKAGE_XLIB_LIBXI
    select BR2_PACKAGE_XLIB_LIBXCURSOR
    help
      SkyEmu is a Game Boy, Game Boy Color, Game Boy Advance, and Nintendo DS
      emulator.

      https://github.com/skylersaleh/SkyEmu

comment "skyemu needs X.org, OpenGL, and a toolchain w/ C++"
    depends on !BR2_INSTALL_LIBSTDCPP || !BR2_PACKAGE_XORG7 || !BR2_PACKAGE_HAS_LIBGL
