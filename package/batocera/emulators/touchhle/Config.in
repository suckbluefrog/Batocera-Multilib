config BR2_PACKAGE_TOUCHHLE
	bool "touchHLE"
	depends on BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY || \
		   BR2_PACKAGE_BATOCERA_TARGET_QCS6490 || \
		   BR2_PACKAGE_BATOCERA_TARGET_SM8250 || \
		   BR2_PACKAGE_BATOCERA_TARGET_SM8550 || \
		   BR2_PACKAGE_BATOCERA_TARGET_RK3568
	depends on BR2_PACKAGE_HOST_RUSTC_TARGET_ARCH_SUPPORTS
	select BR2_PACKAGE_HOST_RUSTC
	select BR2_PACKAGE_HOST_CMAKE
	select BR2_PACKAGE_BOOST
	select BR2_PACKAGE_BATOCERA_SDL2
	select BR2_PACKAGE_OPENAL

	help
	  touchHLE is a high-level emulator for early iPhone OS apps.

	  https://github.com/touchHLE/touchHLE
