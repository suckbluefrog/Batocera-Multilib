config BR2_PACKAGE_GOPHER64
    bool "gopher64"
    depends on BR2_x86_64 || BR2_aarch64
    depends on BR2_PACKAGE_HOST_RUSTC_TARGET_ARCH_SUPPORTS
    select BR2_PACKAGE_HOST_RUSTC
    select BR2_PACKAGE_HOST_CLANG
    select BR2_PACKAGE_HOST_CMAKE
    select BR2_PACKAGE_HOST_NINJA
    select BR2_PACKAGE_ALSA_LIB
    select BR2_PACKAGE_LIBDRM
    select BR2_PACKAGE_MESA3D
    select BR2_PACKAGE_VULKAN_LOADER
    help
      Gopher64 is a Nintendo 64 emulator with Vulkan rendering and a native
      Linux frontend.

      https://github.com/gopher64/gopher64
