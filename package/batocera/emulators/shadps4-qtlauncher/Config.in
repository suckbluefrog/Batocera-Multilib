config BR2_PACKAGE_SHADPS4_QTLAUNCHER
	bool "shadps4-qtlauncher"
	depends on BR2_x86_64
	depends on BR2_TOOLCHAIN_GCC_AT_LEAST_13
	select BR2_HOST_CMAKE_AT_LEAST_3_24
	select BR2_PACKAGE_BATOCERA_QT6
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_SDL3
	select BR2_PACKAGE_VULKAN_HEADERS
	select BR2_PACKAGE_QT6WAYLAND if BR2_PACKAGE_BATOCERA_WAYLAND
	help
	  Qt launcher companion for shadPS4.

	  https://github.com/shadps4-emu/shadps4-qtlauncher
