--- a/cmake/need_phmap.cmake
+++ b/cmake/need_phmap.cmake
@@ -18,15 +18,36 @@
 
 cmake_minimum_required(VERSION 3.28.0)
 
-try_run(
-  PHMAP_RUN_RESULT
-  PHMAP_COMPILE_RESULT
-  SOURCES ${CMAKE_CURRENT_SOURCE_DIR}/cmake/checks/phmap-version.cpp
-  CMAKE_FLAGS -DINCLUDE_DIRECTORIES=${TRY_RUN_INCLUDE_DIRECTORIES}
-  CXX_STANDARD ${DWARFS_CXX_STANDARD}
-  RUN_OUTPUT_VARIABLE PHMAP_VERSION
-  COMPILE_OUTPUT_VARIABLE PHMAP_COMPILE_OUTPUT
-)
+if(CMAKE_CROSSCOMPILING)
+  find_path(PHMAP_INCLUDE_DIR parallel_hashmap/phmap_config.h)
+
+  if(PHMAP_INCLUDE_DIR)
+    file(STRINGS "${PHMAP_INCLUDE_DIR}/parallel_hashmap/phmap_config.h" PHMAP_VERSION_MAJOR_LINE
+      REGEX "^#define PHMAP_VERSION_MAJOR ")
+    file(STRINGS "${PHMAP_INCLUDE_DIR}/parallel_hashmap/phmap_config.h" PHMAP_VERSION_MINOR_LINE
+      REGEX "^#define PHMAP_VERSION_MINOR ")
+    file(STRINGS "${PHMAP_INCLUDE_DIR}/parallel_hashmap/phmap_config.h" PHMAP_VERSION_PATCH_LINE
+      REGEX "^#define PHMAP_VERSION_PATCH ")
+
+    string(REGEX REPLACE "^#define PHMAP_VERSION_MAJOR ([0-9]+)$" "\\1" PHMAP_VERSION_MAJOR "${PHMAP_VERSION_MAJOR_LINE}")
+    string(REGEX REPLACE "^#define PHMAP_VERSION_MINOR ([0-9]+)$" "\\1" PHMAP_VERSION_MINOR "${PHMAP_VERSION_MINOR_LINE}")
+    string(REGEX REPLACE "^#define PHMAP_VERSION_PATCH ([0-9]+)$" "\\1" PHMAP_VERSION_PATCH "${PHMAP_VERSION_PATCH_LINE}")
+    set(PHMAP_VERSION "${PHMAP_VERSION_MAJOR}.${PHMAP_VERSION_MINOR}.${PHMAP_VERSION_PATCH}")
+    set(PHMAP_RUN_RESULT 0)
+  else()
+    set(PHMAP_RUN_RESULT 1)
+  endif()
+else()
+  try_run(
+    PHMAP_RUN_RESULT
+    PHMAP_COMPILE_RESULT
+    SOURCES ${CMAKE_CURRENT_SOURCE_DIR}/cmake/checks/phmap-version.cpp
+    CMAKE_FLAGS -DINCLUDE_DIRECTORIES=${TRY_RUN_INCLUDE_DIRECTORIES}
+    CXX_STANDARD ${DWARFS_CXX_STANDARD}
+    RUN_OUTPUT_VARIABLE PHMAP_VERSION
+    COMPILE_OUTPUT_VARIABLE PHMAP_COMPILE_OUTPUT
+  )
+endif()
 
 if(PHMAP_RUN_RESULT EQUAL 0)
   if(PHMAP_VERSION VERSION_LESS ${PARALLEL_HASHMAP_REQUIRED_VERSION})
