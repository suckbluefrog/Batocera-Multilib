config BR2_PACKAGE_XDG_DESKTOP_PORTAL_GTK
	bool "xdg-desktop-portal-gtk"
	depends on BR2_PACKAGE_XDG_DESKTOP_PORTAL
	depends on BR2_PACKAGE_LIBGTK3
	help
	  xdg-desktop-portal-gtk is a GTK backend for xdg-desktop-portal.
	  It provides interfaces such as FileChooser and AppChooser, used by
	  OpenURI flows in Flatpak apps.

	  https://github.com/flatpak/xdg-desktop-portal-gtk

comment "xdg-desktop-portal-gtk needs xdg-desktop-portal and libgtk3"
	depends on !BR2_PACKAGE_XDG_DESKTOP_PORTAL || !BR2_PACKAGE_LIBGTK3
